{% extends 'base.html.twig' %}

{% block title %}Edit Stock Item{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Edit Stock Item: {{ stock.itemName }}</h1>

    <div class="card mt-4">
        <div class="card-body">
            {{ include('stock/_form.html.twig') }}
        </div>
    </div>

    <div class="mt-3">
        <a href="{{ path('app_stock_index') }}" class="btn btn-outline-secondary">Back to List</a>
        <a href="{{ path('app_stock_show', {'id': stock.id}) }}" class="btn btn-outline-info">View Details</a>
    </div>
</div>
{% endblock %}
