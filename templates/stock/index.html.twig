{% extends 'base.html.twig' %}

{% block title %}Stock Inventory{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Stock Inventory</h1>
        <div>
            <a href="{{ path('app_stock_dashboard') }}" class="btn btn-info me-2">
                <i class="fas fa-chart-pie"></i> Dashboard
            </a>
            <a href="{{ path('app_stock_new') }}" class="btn btn-primary">
                <i class="fas fa-plus"></i> Add Stock Item
            </a>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-6">
                    <input type="text" name="q" class="form-control" placeholder="Search items, SKU, suppliers..." value="{{ q }}">
                </div>
                <div class="col-md-3">
                    <select name="sort" class="form-select">
                        <option value="ASC" {{ sort == 'ASC' ? 'selected' : '' }}>Name (A-Z)</option>
                        <option value="DESC" {{ sort == 'DESC' ? 'selected' : '' }}>Name (Z-A)</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-outline-primary w-100">Search</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>SKU</th>
                            <th>Item Name</th>
                            <th>Supplier</th>
                            <th>Quantity</th>
                            <th>Unit</th>
                            <th>Location</th>
                            <th>Unit Cost</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for stock in stocks %}
                            <tr class="{{ stock.isLowStock ? 'table-warning' : '' }}">
                                <td><code>{{ stock.sku ?: 'N/A' }}</code></td>
                                <td>{{ stock.itemName }}</td>
                                <td>{{ stock.supplier ? stock.supplier.name : 'N/A' }}</td>
                                <td>
                                    <strong>{{ stock.quantity }}</strong>
                                    {% if stock.isLowStock %}
                                        <span class="badge bg-warning text-dark">Low Stock</span>
                                    {% endif %}
                                </td>
                                <td>{{ stock.unit ?: 'units' }}</td>
                                <td>{{ stock.location ?: 'N/A' }}</td>
                                <td>
                                    {% if stock.unitCost %}
                                        ₱{{ stock.unitCost|number_format(2) }}
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>
                                <td>
                                    {% if stock.isLowStock %}
                                        <span class="badge bg-warning text-dark">Low Stock</span>
                                    {% else %}
                                        <span class="badge bg-success">In Stock</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a href="{{ path('app_stock_show', {'id': stock.id}) }}" class="btn btn-sm btn-outline-info" title="View">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="{{ path('app_stock_edit', {'id': stock.id}) }}" class="btn btn-sm btn-outline-primary" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="9" class="text-center">No stock items found</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a href="{{ path('app_supplier_index') }}" class="btn btn-outline-secondary">
            <i class="fas fa-truck"></i> Manage Suppliers
        </a>
    </div>
</div>
{% endblock %}
