{% extends 'base.html.twig' %}

{% block title %}My Profile{% endblock %}

{% block stylesheets %}
<style>
:root {
    --primary-color: #f59e0b;
    --primary-dark: #ea580c;
    --success-color: #10b981;
    --danger-color: #ef4444;
    --info-color: #3b82f6;
    --text-secondary: #6b7280;
    --border-color: #e5e7eb;
    --light-bg: #f9fafb;
}
.admin-page-header {
    background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
    padding: 32px 40px;
    border-radius: 16px;
    margin-bottom: 32px;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    color: white;
}
.admin-page-header h1 {
    margin: 0;
    font-size: 32px;
    font-weight: 700;
}
.admin-card {
    background: white;
    border-radius: 16px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    border: 1px solid var(--border-color);
}
.admin-card-body {
    padding: 32px;
}
.table-admin {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
}
.table-admin th {
    padding: 14px 16px;
    text-align: left;
    font-weight: 600;
    font-size: 14px;
    background: var(--light-bg);
    border-bottom: 2px solid var(--border-color);
    width: 200px;
}
.table-admin td {
    padding: 16px;
    border-bottom: 1px solid var(--border-color);
    font-size: 15px;
}
.badge-admin {
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
}
.badge-danger { background: rgba(239, 68, 68, 0.1); color: var(--danger-color); }
.badge-primary { background: rgba(59, 130, 246, 0.1); color: var(--info-color); }
.badge-success { background: rgba(16, 185, 129, 0.1); color: var(--success-color); }
.badge-secondary { background: rgba(107, 114, 128, 0.1); color: var(--text-secondary); }
.btn-admin-primary {
    background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
    border: none;
    color: white;
    padding: 12px 24px;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
}
.btn-admin-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(245, 158, 11, 0.4);
    color: white;
}
</style>
{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="admin-page-header">
        <div>
            <h1>
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16" style="display: inline-block; margin-right: 12px; vertical-align: middle;">
                    <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
                    <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z"/>
                </svg>
                My Profile
            </h1>
            <p>View and manage your account information</p>
        </div>
    </div>

    <div class="admin-card">
        <div class="admin-card-body">
            <table class="table-admin" style="border: none;">
                <tbody>
                    <tr>
                        <th>Username</th>
                        <td><strong>{{ user.username }}</strong></td>
                    </tr>
                    <tr>
                        <th>Email</th>
                        <td>{{ user.email }}</td>
                    </tr>
                    <tr>
                        <th>Full Name</th>
                        <td>{{ user.fullName ?? '-' }}</td>
                    </tr>
                    <tr>
                        <th>Role</th>
                        <td>
                            {% if 'ROLE_ADMIN' in user.roles %}
                                <span class="badge-admin badge-danger">Admin</span>
                            {% elseif 'ROLE_STAFF' in user.roles %}
                                <span class="badge-admin badge-primary">Staff</span>
                            {% else %}
                                <span class="badge-admin badge-secondary">User</span>
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <th>Status</th>
                        <td>
                            {% if user.isActive %}
                                <span class="badge-admin badge-success">Active</span>
                            {% else %}
                                <span class="badge-admin badge-secondary">Inactive</span>
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <th>Date Created</th>
                        <td>{{ user.createdAt ? user.createdAt|date('F d, Y \a\t H:i') : '-' }}</td>
                    </tr>
                </tbody>
            </table>
            <div style="margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--border-color);">
                <a href="{{ path('app_profile_change_password') }}" class="btn-admin-primary">Change Password</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
