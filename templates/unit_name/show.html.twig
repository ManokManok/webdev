{% extends 'base.html.twig' %}

{% block title %}Product{% endblock %}

{% block body %}
    <h1>Product</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ product.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ product.name }}</td>
            </tr>
            <tr>
                <th>Issue</th>
                <td>{{ product.issue }}</td>
            </tr>
            <tr>
                <th>Price</th>
                <td>{{ product.price }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_unit_name_index') }}">back to list</a>

    <a href="{{ path('app_unit_name_edit', {'id': product.id}) }}">edit</a>

    {{ include('unit_name/_delete_form.html.twig') }}
{% endblock %}
