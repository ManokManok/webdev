{% extends 'staff/base.html.twig' %}

{% block title %}My Profile{% endblock %}

{% block content %}
<div class="admin-page-header" style="display: flex; align-items: center; justify-content: space-between; padding: 40px 48px;">
    <div>
        <h1>
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" fill="currentColor" viewBox="0 0 16 16" style="display: inline-block; margin-right: 16px; vertical-align: middle;">
                <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
                <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z"/>
            </svg>
            My Profile
        </h1>
        <p style="margin: 8px 0 0 0; font-size: 16px; opacity: 0.9;">View and manage your account information</p>
    </div>
</div>

<div class="admin-card" style="border-radius: 20px; box-shadow: 0 10px 20px rgba(0,0,0,0.05); margin: 0 48px 40px 48px; overflow: hidden;">
    <div class="admin-card-header" style="padding: 28px 32px; border-bottom: 1px solid rgba(0,0,0,0.05); background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);">
        <div style="display: flex; align-items: center; gap: 16px;">
            <div style="width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%); display: flex; align-items: center; justify-content: center; color: white; font-size: 32px; font-weight: 800; box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);">
                {{ user.username|slice(0,1)|upper }}
            </div>
            <div>
                <h2 style="margin: 0; font-size: 24px; font-weight: 800; color: #111827;">{{ user.username }}</h2>
                <p style="margin: 4px 0 0 0; font-size: 14px; color: #6b7280;">{{ user.email }}</p>
                <div style="margin-top: 8px;">
                    {% if 'ROLE_STAFF' in user.roles %}
                        <span class="badge-admin badge-primary" style="border: 1px solid rgba(59, 130, 246, 0.3);">Staff</span>
                    {% elseif 'ROLE_ADMIN' in user.roles %}
                        <span class="badge-admin badge-danger" style="border: 1px solid rgba(239, 68, 68, 0.3);">Admin</span>
                    {% else %}
                        <span class="badge-admin badge-secondary" style="border: 1px solid rgba(107, 114, 128, 0.3);">User</span>
                    {% endif %}
                    {% if user.isActive %}
                        <span class="badge-admin badge-success" style="border: 1px solid rgba(34, 197, 94, 0.3); margin-left: 8px;">Active</span>
                    {% else %}
                        <span class="badge-admin badge-secondary" style="border: 1px solid rgba(107, 114, 128, 0.3); margin-left: 8px;">Inactive</span>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
    <div class="admin-card-body" style="padding: 32px;">
        <table class="table-admin" style="border: none; width: 100%;">
            <tbody>
                <tr>
                    <th style="width: 200px; background: #f8fafc; padding: 16px 20px; font-weight: 700; color: #111827; border-bottom: 1px solid #e5e7eb;">Name</th>
                    <td style="padding: 16px 20px; border-bottom: 1px solid #e5e7eb; font-size: 15px; color: #374151;"><strong>{{ user.username }}</strong></td>
                </tr>
                <tr>
                    <th style="background: #f8fafc; padding: 16px 20px; font-weight: 700; color: #111827; border-bottom: 1px solid #e5e7eb;">Email</th>
                    <td style="padding: 16px 20px; border-bottom: 1px solid #e5e7eb; font-size: 15px; color: #374151;">{{ user.email }}</td>
                </tr>
                <tr>
                    <th style="background: #f8fafc; padding: 16px 20px; font-weight: 700; color: #111827; border-bottom: 1px solid #e5e7eb;">Role</th>
                    <td style="padding: 16px 20px; border-bottom: 1px solid #e5e7eb; font-size: 15px; color: #374151;">
                        {% if 'ROLE_ADMIN' in user.roles %}
                            <span class="badge-admin badge-danger" style="border: 1px solid rgba(239, 68, 68, 0.3);">Admin</span>
                        {% elseif 'ROLE_STAFF' in user.roles %}
                            <span class="badge-admin badge-primary" style="border: 1px solid rgba(59, 130, 246, 0.3);">Staff</span>
                        {% else %}
                            <span class="badge-admin badge-secondary" style="border: 1px solid rgba(107, 114, 128, 0.3);">User</span>
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <th style="background: #f8fafc; padding: 16px 20px; font-weight: 700; color: #111827; border-bottom: 1px solid #e5e7eb;">Status</th>
                    <td style="padding: 16px 20px; border-bottom: 1px solid #e5e7eb; font-size: 15px; color: #374151;">
                        {% if user.isActive %}
                            <span class="badge-admin badge-success" style="border: 1px solid rgba(34, 197, 94, 0.3);">Active</span>
                        {% else %}
                            <span class="badge-admin badge-secondary" style="border: 1px solid rgba(107, 114, 128, 0.3);">Inactive</span>
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <th style="background: #f8fafc; padding: 16px 20px; font-weight: 700; color: #111827; border-bottom: 1px solid #e5e7eb;">Date Created</th>
                    <td style="padding: 16px 20px; border-bottom: 1px solid #e5e7eb; font-size: 15px; color: #374151;">{{ user.createdAt ? user.createdAt|date('F d, Y \a\t H:i') : '-' }}</td>
                </tr>
            </tbody>
        </table>
        <div style="margin-top: 32px; padding-top: 24px; border-top: 2px solid #e5e7eb; display: flex; gap: 12px;">
            <a href="{{ path('app_profile_change_password') }}" class="btn-admin-primary" style="background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%); border: none; color: white; padding: 12px 24px; border-radius: 8px; font-weight: 700; text-decoration: none; transition: all 0.3s ease; display: inline-flex; align-items: center; gap: 8px; box-shadow: 0 4px 12px rgba(234, 88, 12, 0.25);">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
                </svg>
                Change Password
            </a>
        </div>
    </div>
</div>

<style>
.badge-admin {
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 700;
    display: inline-block;
}
.badge-danger { background: rgba(239, 68, 68, 0.1); color: #ef4444; }
.badge-primary { background: rgba(59, 130, 246, 0.1); color: #3b82f6; }
.badge-success { background: rgba(34, 197, 94, 0.1); color: #22c55e; }
.badge-secondary { background: rgba(107, 114, 128, 0.1); color: #6b7280; }
.btn-admin-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(234, 88, 12, 0.35);
}
</style>
{% endblock %}

