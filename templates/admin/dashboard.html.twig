{% extends 'admin/base.html.twig' %}

{% block title %}Admin Dashboard{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="{{ asset('css/admindashboard.css') }}?v=2">
{% endblock %}

{% block content %}
<!-- Background canvas -->
<div class="db-canvas"></div>

<!-- Decorative rings (top-right) -->
<div class="deco-rings">
  <div class="ring"></div>
  <div class="ring"></div>
</div>

<div class="dashboard-root">

  <!-- ── HEADER ── -->
  <header class="db-header">
    <div class="db-header-left">
      <h1>Booking &amp; Service Hub</h1>
      <p>Live overview of bookings, orders, and payments from the mobile app.</p>
    </div>
    <div class="db-header-right">
      <!-- Date Badge -->
      <div class="db-date-badge">
        <span class="dot"></span>
        <span id="liveDateLabel">Loading…</span>
      </div>
    </div>
  </header>

  <!-- ── BOOKING HUB METRICS ── -->
  <section class="booking-hub-strip">
    <a href="{{ path('app_admin_bookings') }}" class="hub-card hub-bookings">
      <div class="hub-card-top">
        <span class="hub-icon"><i data-feather="calendar"></i></span>
        <span class="hub-badge" data-realtime-count="pendingBookings">{{ pendingBookings }} pending</span>
      </div>
      <div class="hub-val" data-hub-count="totalBookings" data-count="{{ totalBookings }}">0</div>
      <div class="hub-label">Total Bookings</div>
      <div class="hub-sub">{{ confirmedBookings }} confirmed</div>
    </a>
    <a href="{{ path('app_admin_orders') }}" class="hub-card hub-orders">
      <div class="hub-card-top">
        <span class="hub-icon"><i data-feather="shopping-bag"></i></span>
        <span class="hub-badge" data-realtime-count="pendingOrders">{{ pendingOrders }} unpaid</span>
      </div>
      <div class="hub-val" data-hub-count="totalOrders" data-count="{{ totalOrders }}">0</div>
      <div class="hub-label">Total Orders</div>
      <div class="hub-sub">{{ paidOrders }} paid</div>
    </a>
    <a href="{{ path('app_admin_payments') }}" class="hub-card hub-payments">
      <div class="hub-card-top">
        <span class="hub-icon"><i data-feather="credit-card"></i></span>
        <span class="hub-badge">{{ completedPayments }} completed</span>
      </div>
      <div class="hub-val" data-hub-count="totalPayments" data-count="{{ totalPayments }}">0</div>
      <div class="hub-label">Total Payments</div>
      <div class="hub-sub">All transactions</div>
    </a>
    <div class="hub-card hub-revenue">
      <div class="hub-card-top">
        <span class="hub-icon"><i data-feather="trending-up"></i></span>
        <span class="hub-badge hub-badge-light">Revenue</span>
      </div>
      <div class="hub-val hub-val-currency" data-hub-count="totalRevenue" data-count="{{ totalRevenue }}" data-prefix="₱" data-decimals="2">₱0</div>
      <div class="hub-label">Total Collected</div>
      <div class="hub-sub">From completed payments</div>
    </div>
  </section>

  <!-- ── SECONDARY METRICS ── -->
  <section class="metrics-strip metrics-strip-secondary">
    <div class="metric-card">
      <div class="metric-icon"><i data-feather="users"></i></div>
      <div>
        <div class="metric-label">Customers</div>
        <div class="metric-val" data-count="{{ totalUsers }}">0</div>
      </div>
    </div>
    <div class="metric-card">
      <div class="metric-icon"><i data-feather="user"></i></div>
      <div>
        <div class="metric-label">Staff</div>
        <div class="metric-val" data-count="{{ totalStaff }}">0</div>
      </div>
    </div>
    <div class="metric-card">
      <div class="metric-icon"><i data-feather="package"></i></div>
      <div>
        <div class="metric-label">Services</div>
        <div class="metric-val" data-count="{{ totalProducts }}">0</div>
      </div>
    </div>
    <div class="metric-card">
      <div class="metric-icon"><i data-feather="folder"></i></div>
      <div>
        <div class="metric-label">Categories</div>
        <div class="metric-val" data-count="{{ totalCategories }}">0</div>
      </div>
    </div>
    <div class="metric-card">
      <div class="metric-icon"><i data-feather="briefcase"></i></div>
      <div>
        <div class="metric-label">Suppliers</div>
        <div class="metric-val" data-count="{{ totalSuppliers }}">0</div>
      </div>
    </div>
  </section>

  <!-- ── ACTIVITY GRID ── -->
  <div class="activity-grid">

    <div class="activity-panel">
      <div class="panel-head">
        <h3><i data-feather="calendar"></i> Recent Bookings</h3>
        <a href="{{ path('app_admin_bookings') }}">View all →</a>
      </div>
      <ul class="activity-list">
        {% for b in recentBookings %}
        <li class="activity-row">
          <div class="avatar-sm">{{ b.product.name|slice(0,1)|upper }}</div>
          <div class="activity-body">
            <div class="activity-title">{{ b.product.name }}</div>
            <div class="activity-meta">{{ b.user.fullName|default(b.user.username) }} · {{ b.scheduledAt|date('M d, Y') }}</div>
          </div>
          <span class="status-pill status-{{ b.status|lower }}">{{ b.status }}</span>
        </li>
        {% else %}
        <li class="activity-row empty">No bookings yet — data appears when customers use the app.</li>
        {% endfor %}
      </ul>
    </div>

    <div class="activity-panel">
      <div class="panel-head">
        <h3><i data-feather="shopping-bag"></i> Recent Orders</h3>
        <a href="{{ path('app_admin_orders') }}">View all →</a>
      </div>
      <ul class="activity-list">
        {% for o in recentOrders %}
        <li class="activity-row">
          <div class="avatar-sm">{{ o.product.name|slice(0,1)|upper }}</div>
          <div class="activity-body">
            <div class="activity-title">Order #{{ o.id }} — ₱{{ o.totalAmount|number_format(2) }}</div>
            <div class="activity-meta">{{ o.user.fullName|default(o.user.username) }} · {{ o.product.name }}</div>
          </div>
          <span class="status-pill status-{{ o.status|lower }}">{{ o.status }}</span>
        </li>
        {% else %}
        <li class="activity-row empty">No orders yet.</li>
        {% endfor %}
      </ul>
    </div>

    <div class="activity-panel">
      <div class="panel-head">
        <h3><i data-feather="credit-card"></i> Recent Payments</h3>
        <a href="{{ path('app_admin_payments') }}">View all →</a>
      </div>
      <ul class="activity-list">
        {% for p in recentPayments %}
        <li class="activity-row">
          <div class="avatar-sm">₱</div>
          <div class="activity-body">
            <div class="activity-title">₱{{ p.amount|number_format(2) }} — {{ p.method|capitalize }}</div>
            <div class="activity-meta">{{ p.user.fullName|default(p.user.username) }} · Order #{{ p.order.id }}</div>
          </div>
          <span class="status-pill status-{{ p.status|lower }}">{{ p.status }}</span>
        </li>
        {% else %}
        <li class="activity-row empty">No payments yet.</li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <!-- ── INVENTORY ROW ── -->
  <div class="main-grid">
    <div class="turnover-card">
      <div class="turnover-top">
        <div>
          <div class="turnover-label">Revenue Overview</div>
          <div class="turnover-amount">₱{{ totalRevenue|number_format(2) }}</div>
          <div class="turnover-sub">{{ completedPayments }} completed payment{{ completedPayments != 1 ? 's' : '' }} · {{ paidOrders }} paid orders</div>
        </div>
        <a href="{{ path('app_admin_payments') }}" class="turnover-link">Payments →</a>
      </div>
      <div class="chart-wrap">
        <canvas id="turnoverChart"></canvas>
      </div>
    </div>

    <div class="stock-card">
      <div class="stock-head">
        <div class="stock-title">Inventory &amp; Services</div>
        <div class="stock-badges">
          <span class="badge in"><i class="fas fa-check-circle"></i> {{ inStockCount|default(0) }} In Stock</span>
          <span class="badge low"><i class="fas fa-exclamation-triangle"></i> {{ lowStockCount|default(0) }} Low</span>
        </div>
      </div>
      <ul id="recentList" class="recent-list">
        {% for p in recent %}
          <li class="recent-row" data-name="{{ p.name|lower }}">
            <div class="avatar-sm">{{ p.name|slice(0,1)|upper }}</div>
            <div>
              <div class="ri-name">{{ p.name }}</div>
              <div class="ri-price">₱{{ p.price|number_format(2) }}</div>
            </div>
            <a href="{{ path('app_product_show', {id:p.id}) }}" class="row-action">Details</a>
          </li>
        {% else %}
          <li class="recent-row empty">No services yet</li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <!-- ── BRANDS ── -->
  <section class="brands-section">
    <div class="brands-section-head">
      <div class="brands-section-title">Brands We Service</div>
      <span class="brands-count">15 brands</span>
    </div>
    <div class="brands-grid">
      {% set brands = [
        {name:'Apple',    url:'https://cdn.simpleicons.org/apple/ea580c',    href:'https://www.apple.com/'},
        {name:'Asus',     url:'https://cdn.simpleicons.org/asus/ea580c',     href:'https://www.asus.com/'},
        {name:'Huawei',   url:'https://cdn.simpleicons.org/huawei/ea580c',   href:'https://consumer.huawei.com/'},
        {name:'Infinix',  url:'https://cdn.simpleicons.org/infinix/ea580c',  href:'https://www.infinixmobility.com/'},
        {name:'Lenovo',   url:'https://cdn.simpleicons.org/lenovo/ea580c',   href:'https://www.lenovo.com/'},
        {name:'Motorola', url:'https://cdn.simpleicons.org/motorola/ea580c', href:'https://www.motorola.com/'},
        {name:'Nokia',    url:'https://cdn.simpleicons.org/nokia/ea580c',    href:'https://www.nokia.com/phones/'},
        {name:'OnePlus',  url:'https://cdn.simpleicons.org/oneplus/ea580c',  href:'https://www.oneplus.com/'},
        {name:'OPPO',     url:'https://cdn.simpleicons.org/oppo/ea580c',     href:'https://www.oppo.com/'},
        {name:'realme',   url:'https://cdn.simpleicons.org/realme/ea580c',   href:'https://www.realme.com/'},
        {name:'Samsung',  url:'https://cdn.simpleicons.org/samsung/ea580c',  href:'https://www.samsung.com/'},
        {name:'Sony',     url:'https://cdn.simpleicons.org/sony/ea580c',     href:'https://www.sony.com/'},
        {name:'TECNO',    url:'https://cdn.simpleicons.org/tecno/ea580c',    href:'https://www.tecno-mobile.com/'},
        {name:'vivo',     url:'https://cdn.simpleicons.org/vivo/ea580c',     href:'https://www.vivo.com/'},
        {name:'Xiaomi',   url:'https://cdn.simpleicons.org/xiaomi/ea580c',   href:'https://www.mi.com/'}
      ] %}
      {% for b in brands|sort((a,b) => a.name <=> b.name) %}
      <a href="{{ b.href|default('#') }}" class="brand-chip" target="_blank" rel="noopener noreferrer" title="{{ b.name }}">
        <img loading="lazy" decoding="async" referrerpolicy="no-referrer"
             src="{{ b.url }}" alt="{{ b.name }}"
             onerror="this.style.display='none'; this.nextElementSibling.style.display='inline'">
        <span class="brand-fallback">{{ b.name|slice(0,1) }}</span>
        <span class="brand-name">{{ b.name }}</span>
      </a>
      {% endfor %}
    </div>
  </section>

  <!-- ── CTA BANNER ── -->
  {# <section class="cta-banner">
    <div class="cta-text">
      <h3>Create your CRM profile with us.</h3>
      <p>Manage your workflow with a simplified version of our services.</p>
    </div>
    <a href="#" class="cta-btn">Get Started →</a>
  </section> #}

</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="{{ asset('vendor/chart.js/chart.umd.min.js') }}"></script>
<script>
/* ── LIVE DATE ── */
(function() {
  const el = document.getElementById('liveDateLabel');
  if (!el) return;
  function fmt() {
    const d = new Date();
    return d.toLocaleDateString('en-PH', { weekday:'short', month:'short', day:'numeric', year:'numeric' });
  }
  el.textContent = fmt();
})();

/* ── COUNT-UP ANIMATION ── */
function countUp(el, target, duration) {
  const start = performance.now();
  const prefix = el.dataset.prefix || '';
  const decimals = parseInt(el.dataset.decimals || '0', 10);
  const isFloat = decimals > 0 || target % 1 !== 0;
  (function step(now) {
    const p = Math.min((now - start) / duration, 1);
    const ease = 1 - Math.pow(1 - p, 4);
    const val = target * ease;
    el.textContent = prefix + (isFloat ? val.toFixed(decimals) : Math.round(val).toLocaleString());
    if (p < 1) requestAnimationFrame(step);
    else el.textContent = prefix + (isFloat ? target.toFixed(decimals) : target.toLocaleString());
  })(start);
}

const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      const els = entry.target.querySelectorAll('[data-count]');
      els.forEach((el, i) => {
        const val = parseFloat(el.dataset.count || 0);
        setTimeout(() => countUp(el, val, 1200), i * 100);
      });
      observer.unobserve(entry.target);
    }
  });
}, { threshold: 0.2 });

document.querySelectorAll('.booking-hub-strip, .metrics-strip').forEach(strip => {
  if (strip) observer.observe(strip);
});

/* ── FILTER ── */
function filterRecent(q) {
  const list = document.getElementById('recentList');
  if (!list) return;
  const term = (q || '').toLowerCase();
  let visible = 0;
  list.querySelectorAll('.recent-row').forEach(li => {
    if (li.classList.contains('empty')) return;
    const match = (li.dataset.name || '').includes(term);
    li.style.display = match ? '' : 'none';
    if (match) visible++;
  });
  const emptyRow = list.querySelector('.recent-row.empty');
  if (emptyRow) emptyRow.style.display = visible === 0 ? '' : 'none';
}

/* ── TURNOVER CHART ── */
const ctx = document.getElementById('turnoverChart');
if (ctx && typeof Chart !== 'undefined') {
  const gCtx = ctx.getContext('2d');

  const areaGrad = gCtx.createLinearGradient(0, 0, 0, 150);
  areaGrad.addColorStop(0,   'rgba(255,255,255,0.45)');
  areaGrad.addColorStop(0.5, 'rgba(255,255,255,0.15)');
  areaGrad.addColorStop(1,   'rgba(255,255,255,0.02)');

  const base = {{ totalRevenue|default(0) }} / 1000 || 1;
  const data = [base*.40, base*.55, base*.45, base*.70, base*.85, base*.65, base*1.0];

  new Chart(ctx, {
    type: 'line',
    data: {
      labels: ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'],
      datasets: [{
        label: 'Value (₱K)',
        data,
        fill: true,
        tension: 0.42,
        borderColor: 'rgba(255,255,255,0.95)',
        backgroundColor: areaGrad,
        borderWidth: 2.5,
        pointRadius: 4,
        pointHoverRadius: 7,
        pointBackgroundColor: '#fff',
        pointBorderColor: 'rgba(255,255,255,0.6)',
        pointBorderWidth: 2,
        pointHoverBackgroundColor: '#ea580c',
        pointHoverBorderColor: '#fff',
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: 'rgba(26,10,0,0.85)',
          padding: 10,
          cornerRadius: 8,
          titleFont: { size: 11, weight: '600', family: 'DM Sans' },
          bodyFont:  { size: 12, family: 'DM Sans' },
          displayColors: false,
          callbacks: { label: c => '₱' + c.parsed.y.toFixed(1) + 'K' }
        }
      },
      scales: {
        x: { display: false },
        y: { display: false, min: 0 }
      },
      animation: {
        duration: 2000,
        easing: 'easeOutQuart',
        delay: c => c.type === 'dataPoint' ? c.dataIndex * 130 : 0
      }
    }
  });
}
</script>
{% endblock %}
