{% extends 'admin/base.html.twig' %}

{% block title %}Admin Dashboard{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="{{ asset('css/admindashboard.css') }}">
{% endblock %}

{% block content %}
<!-- Background canvas -->
<div class="db-canvas"></div>

<!-- Decorative rings (top-right) -->
<div class="deco-rings">
  <div class="ring"></div>
  <div class="ring"></div>
</div>

<div class="dashboard-root">

  <!-- ── HEADER ── -->
  <header class="db-header">
    <div class="db-header-left">
      <h1>Dashboard Overview</h1>
      <p>Welcome back — here's what's happening today.</p>
    </div>
    <div class="db-header-right">
      <!-- Notification Button -->
      <div class="notification-wrapper">
        <button class="notification-btn" id="notificationBtn" aria-label="Notifications">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
          </svg>
          <span class="notification-badge" id="notificationCount">3</span>
        </button>
        <div class="notification-dropdown" id="notificationDropdown">
          <div class="notification-header">
            <h4>Messages & Requests</h4>
            <span class="mark-read" id="markAllRead">Mark all read</span>
          </div>
          <div class="notification-list" id="notificationList">
            <!-- Sample notifications - replace with dynamic data -->
            <a href="#" class="notification-item unread">
              <div class="notification-avatar">JD</div>
              <div class="notification-content">
                <div class="notification-title">New repair request</div>
                <div class="notification-text">iPhone 13 Pro screen replacement inquiry from John D.</div>
                <div class="notification-time">2 min ago</div>
              </div>
            </a>
            <a href="#" class="notification-item unread">
              <div class="notification-avatar">SM</div>
              <div class="notification-content">
                <div class="notification-title">Customer message</div>
                <div class="notification-text">Question about Samsung Galaxy warranty coverage</div>
                <div class="notification-time">15 min ago</div>
              </div>
            </a>
            <a href="#" class="notification-item">
              <div class="notification-avatar">AK</div>
              <div class="notification-content">
                <div class="notification-title">Quote request</div>
                <div class="notification-text">iPad Air battery replacement quote requested</div>
                <div class="notification-time">1 hour ago</div>
              </div>
            </a>
          </div>
          <div class="notification-footer">
            <a href="#">View all messages</a>
          </div>
        </div>
      </div>
      <!-- Date Badge -->
      <div class="db-date-badge">
        <span class="dot"></span>
        <span id="liveDateLabel">Loading…</span>
      </div>
    </div>
  </header>

  <!-- ── METRICS STRIP ── -->
  <section class="metrics-strip">
    <div class="metric-card">
      <div class="metric-icon"><i data-feather="users"></i></div>
      <div>
        <div class="metric-label">Total Users</div>
        <div class="metric-val" data-count="{{ totalUsers }}">0</div>
      </div>
    </div>
    <div class="metric-card">
      <div class="metric-icon"><i data-feather="user"></i></div>
      <div>
        <div class="metric-label">Total Staff</div>
        <div class="metric-val" data-count="{{ totalStaff }}">0</div>
      </div>
    </div>
    <div class="metric-card">
      <div class="metric-icon"><i data-feather="package"></i></div>
      <div>
        <div class="metric-label">Products</div>
        <div class="metric-val" data-count="{{ totalProducts }}">0</div>
      </div>
    </div>
    <div class="metric-card">
      <div class="metric-icon"><i data-feather="folder"></i></div>
      <div>
        <div class="metric-label">Categories</div>
        <div class="metric-val" data-count="{{ totalCategories }}">0</div>
      </div>
    </div>
    <div class="metric-card">
      <div class="metric-icon"><i data-feather="briefcase"></i></div>
      <div>
        <div class="metric-label">Suppliers</div>
        <div class="metric-val" data-count="{{ totalSuppliers }}">0</div>
      </div>
    </div>
  </section>

  <!-- ── MAIN GRID ── -->
  <div class="main-grid">

    <!-- Turnover Chart -->
    <div class="turnover-card">
      <div class="turnover-top">
        <div>
          <div class="turnover-label">Inventory Turnover</div>
          <div class="turnover-amount">₱{{ totalValue|number_format(2) }}</div>
          <div class="turnover-sub">Total inventory value · updated now</div>
        </div>
        <a href="{{ path('app_product_index') }}" class="turnover-link">View All →</a>
      </div>
      <div class="chart-wrap">
        <canvas id="turnoverChart"></canvas>
      </div>
    </div>

    <!-- Stock Overview -->
    <div class="stock-card">
      <div class="stock-head">
        <div class="stock-title">Stock Overview</div>
        <div class="stock-badges">
          <span class="badge in"><i class="fas fa-check-circle"></i> {{ inStockCount|default(0) }} In Stock</span>
          <span class="badge low"><i class="fas fa-exclamation-triangle"></i> {{ lowStockCount|default(0) }} Low</span>
        </div>
      </div>
      <ul id="recentList" class="recent-list">
        {% for p in recent %}
          <li class="recent-row" data-name="{{ p.name|lower }}">
            <div class="avatar-sm">{{ p.name|slice(0,1)|upper }}</div>
            <div>
              <div class="ri-name">{{ p.name }}</div>
              <div class="ri-price">₱{{ p.price|number_format(2) }}</div>
            </div>
            <a href="{{ path('app_product_show', {id:p.id}) }}" class="row-action">Details</a>
          </li>
        {% else %}
          <li class="recent-row empty">No items yet</li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <!-- ── BRANDS ── -->
  <section class="brands-section">
    <div class="brands-section-head">
      <div class="brands-section-title">Brands We Service</div>
      <span class="brands-count">15 brands</span>
    </div>
    <div class="brands-grid">
      {% set brands = [
        {name:'Apple',    url:'https://cdn.simpleicons.org/apple/ea580c',    href:'https://www.apple.com/'},
        {name:'Asus',     url:'https://cdn.simpleicons.org/asus/ea580c',     href:'https://www.asus.com/'},
        {name:'Huawei',   url:'https://cdn.simpleicons.org/huawei/ea580c',   href:'https://consumer.huawei.com/'},
        {name:'Infinix',  url:'https://cdn.simpleicons.org/infinix/ea580c',  href:'https://www.infinixmobility.com/'},
        {name:'Lenovo',   url:'https://cdn.simpleicons.org/lenovo/ea580c',   href:'https://www.lenovo.com/'},
        {name:'Motorola', url:'https://cdn.simpleicons.org/motorola/ea580c', href:'https://www.motorola.com/'},
        {name:'Nokia',    url:'https://cdn.simpleicons.org/nokia/ea580c',    href:'https://www.nokia.com/phones/'},
        {name:'OnePlus',  url:'https://cdn.simpleicons.org/oneplus/ea580c',  href:'https://www.oneplus.com/'},
        {name:'OPPO',     url:'https://cdn.simpleicons.org/oppo/ea580c',     href:'https://www.oppo.com/'},
        {name:'realme',   url:'https://cdn.simpleicons.org/realme/ea580c',   href:'https://www.realme.com/'},
        {name:'Samsung',  url:'https://cdn.simpleicons.org/samsung/ea580c',  href:'https://www.samsung.com/'},
        {name:'Sony',     url:'https://cdn.simpleicons.org/sony/ea580c',     href:'https://www.sony.com/'},
        {name:'TECNO',    url:'https://cdn.simpleicons.org/tecno/ea580c',    href:'https://www.tecno-mobile.com/'},
        {name:'vivo',     url:'https://cdn.simpleicons.org/vivo/ea580c',     href:'https://www.vivo.com/'},
        {name:'Xiaomi',   url:'https://cdn.simpleicons.org/xiaomi/ea580c',   href:'https://www.mi.com/'}
      ] %}
      {% for b in brands|sort((a,b) => a.name <=> b.name) %}
      <a href="{{ b.href|default('#') }}" class="brand-chip" target="_blank" rel="noopener noreferrer" title="{{ b.name }}">
        <img loading="lazy" decoding="async" referrerpolicy="no-referrer"
             src="{{ b.url }}" alt="{{ b.name }}"
             onerror="this.style.display='none'; this.nextElementSibling.style.display='inline'">
        <span class="brand-fallback">{{ b.name|slice(0,1) }}</span>
        <span class="brand-name">{{ b.name }}</span>
      </a>
      {% endfor %}
    </div>
  </section>

  <!-- ── CTA BANNER ── -->
  {# <section class="cta-banner">
    <div class="cta-text">
      <h3>Create your CRM profile with us.</h3>
      <p>Manage your workflow with a simplified version of our services.</p>
    </div>
    <a href="#" class="cta-btn">Get Started →</a>
  </section> #}

</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="{{ asset('vendor/chart.js/chart.umd.min.js') }}"></script>
<script>
/* ── LIVE DATE ── */
(function() {
  const el = document.getElementById('liveDateLabel');
  if (!el) return;
  function fmt() {
    const d = new Date();
    return d.toLocaleDateString('en-PH', { weekday:'short', month:'short', day:'numeric', year:'numeric' });
  }
  el.textContent = fmt();
})();

/* ── NOTIFICATION DROPDOWN ── */
(function() {
  const btn = document.getElementById('notificationBtn');
  const dropdown = document.getElementById('notificationDropdown');
  const markRead = document.getElementById('markAllRead');
  const badge = document.getElementById('notificationCount');
  const wrapper = document.querySelector('.notification-wrapper');
  
  if (!btn || !dropdown) return;
  
  // Move dropdown to body to escape all stacking contexts
  document.body.appendChild(dropdown);
  dropdown.style.position = 'fixed';
  dropdown.style.zIndex = '2147483647';
  
  function positionDropdown() {
    const rect = btn.getBoundingClientRect();
    dropdown.style.top = (rect.bottom + 10) + 'px';
    dropdown.style.right = (window.innerWidth - rect.right) + 'px';
  }
  
  // Toggle dropdown
  btn.addEventListener('click', (e) => {
    e.stopPropagation();
    if (!dropdown.classList.contains('active')) {
      positionDropdown();
    }
    dropdown.classList.toggle('active');
  });
  
  // Reposition on resize
  window.addEventListener('resize', () => {
    if (dropdown.classList.contains('active')) {
      positionDropdown();
    }
  });
  
  // Close when clicking outside
  document.addEventListener('click', (e) => {
    if (!dropdown.contains(e.target) && !btn.contains(e.target)) {
      dropdown.classList.remove('active');
    }
  });
  
  // Mark all as read
  if (markRead) {
    markRead.addEventListener('click', () => {
      const unreadItems = dropdown.querySelectorAll('.notification-item.unread');
      unreadItems.forEach(item => item.classList.remove('unread'));
      if (badge) badge.style.display = 'none';
    });
  }
  
  // Individual item click - mark as read
  dropdown.querySelectorAll('.notification-item').forEach(item => {
    item.addEventListener('click', () => {
      item.classList.remove('unread');
      updateBadge();
    });
  });
  
  function updateBadge() {
    const unreadCount = dropdown.querySelectorAll('.notification-item.unread').length;
    if (badge) {
      if (unreadCount > 0) {
        badge.textContent = unreadCount;
        badge.style.display = 'flex';
      } else {
        badge.style.display = 'none';
      }
    }
  }
})();

/* ── COUNT-UP ANIMATION ── */
function countUp(el, target, duration) {
  const start = performance.now();
  const isFloat = target % 1 !== 0;
  (function step(now) {
    const p = Math.min((now - start) / duration, 1);
    const ease = 1 - Math.pow(1 - p, 4);
    el.textContent = isFloat
      ? (target * ease).toFixed(2)
      : Math.round(target * ease).toLocaleString();
    if (p < 1) requestAnimationFrame(step);
    else el.textContent = isFloat ? target.toFixed(2) : target.toLocaleString();
  })(start);
}

const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      const els = entry.target.querySelectorAll('[data-count]');
      els.forEach((el, i) => {
        const val = parseFloat(el.dataset.count || 0);
        setTimeout(() => countUp(el, val, 1200), i * 100);
      });
      observer.unobserve(entry.target);
    }
  });
}, { threshold: 0.2 });

const strip = document.querySelector('.metrics-strip');
if (strip) observer.observe(strip);

/* ── FILTER ── */
function filterRecent(q) {
  const list = document.getElementById('recentList');
  if (!list) return;
  const term = (q || '').toLowerCase();
  let visible = 0;
  list.querySelectorAll('.recent-row').forEach(li => {
    if (li.classList.contains('empty')) return;
    const match = (li.dataset.name || '').includes(term);
    li.style.display = match ? '' : 'none';
    if (match) visible++;
  });
  const emptyRow = list.querySelector('.recent-row.empty');
  if (emptyRow) emptyRow.style.display = visible === 0 ? '' : 'none';
}

/* ── TURNOVER CHART ── */
const ctx = document.getElementById('turnoverChart');
if (ctx && typeof Chart !== 'undefined') {
  const gCtx = ctx.getContext('2d');

  const areaGrad = gCtx.createLinearGradient(0, 0, 0, 150);
  areaGrad.addColorStop(0,   'rgba(255,255,255,0.45)');
  areaGrad.addColorStop(0.5, 'rgba(255,255,255,0.15)');
  areaGrad.addColorStop(1,   'rgba(255,255,255,0.02)');

  const base = {{ totalValue|default(269100) }} / 1000;
  const data = [base*.60, base*.75, base*.55, base*.82, base*.95, base*.78, base*1.0];

  new Chart(ctx, {
    type: 'line',
    data: {
      labels: ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'],
      datasets: [{
        label: 'Value (₱K)',
        data,
        fill: true,
        tension: 0.42,
        borderColor: 'rgba(255,255,255,0.95)',
        backgroundColor: areaGrad,
        borderWidth: 2.5,
        pointRadius: 4,
        pointHoverRadius: 7,
        pointBackgroundColor: '#fff',
        pointBorderColor: 'rgba(255,255,255,0.6)',
        pointBorderWidth: 2,
        pointHoverBackgroundColor: '#ea580c',
        pointHoverBorderColor: '#fff',
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: 'rgba(26,10,0,0.85)',
          padding: 10,
          cornerRadius: 8,
          titleFont: { size: 11, weight: '600', family: 'DM Sans' },
          bodyFont:  { size: 12, family: 'DM Sans' },
          displayColors: false,
          callbacks: { label: c => '₱' + c.parsed.y.toFixed(1) + 'K' }
        }
      },
      scales: {
        x: { display: false },
        y: { display: false, min: 0 }
      },
      animation: {
        duration: 2000,
        easing: 'easeOutQuart',
        delay: c => c.type === 'dataPoint' ? c.dataIndex * 130 : 0
      }
    }
  });
}
</script>
{% endblock %}
