{% extends 'base.html.twig' %}

{% block title %}Activity Log Details{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h3 class="mb-0">Activity Log Details</h3>
                    <a href="{{ path('app_activity_logs') }}" class="btn btn-sm btn-secondary">Back to Logs</a>
                </div>
                <div class="card-body">
                    <table class="table">
                        <tr>
                            <th width="200">Log ID:</th>
                            <td>{{ log.id }}</td>
                        </tr>
                        <tr>
                            <th>User:</th>
                            <td>
                                {% if log.user %}
                                    {{ log.user.username }} ({{ log.user.email }})
                                {% else %}
                                    System
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <th>User Role:</th>
                            <td>
                                {% if log.user %}
                                    {% if 'ROLE_ADMIN' in log.user.roles %}
                                        <span class="badge bg-danger">Admin</span>
                                    {% elseif 'ROLE_STAFF' in log.user.roles %}
                                        <span class="badge bg-primary">Staff</span>
                                    {% else %}
                                        <span class="badge bg-secondary">User</span>
                                    {% endif %}
                                {% else %}
                                    <span class="badge bg-secondary">-</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <th>Action:</th>
                            <td>
                                <span class="badge bg-{{ log.action == 'CREATE' ? 'success' : (log.action == 'UPDATE' ? 'primary' : (log.action == 'DELETE' ? 'danger' : 'info')) }}">
                                    {{ log.action }}
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <th>Entity:</th>
                            <td>{{ log.entity }}</td>
                        </tr>
                        <tr>
                            <th>Entity ID:</th>
                            <td>{{ log.entityId ?? '-' }}</td>
                        </tr>
                        <tr>
                            <th>Details:</th>
                            <td>
                                {% if log.details %}
                                    <pre class="bg-light p-3 rounded">{{ log.details }}</pre>
                                {% else %}
                                    -
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <th>Timestamp:</th>
                            <td>{{ log.createdAt|date('Y-m-d H:i:s') }}</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

