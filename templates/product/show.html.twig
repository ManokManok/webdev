{# templates/product/show.html.twig #}
{% extends 'product/base.html.twig' %}

{% block title %}Product{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Page Container */
        .page-container {
            max-width: 100%;
            margin: 0;
            padding: 0;
        }

        /* Page Header */
        .page-header {
            background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%);
            padding: 28px 32px;
            border-radius: 16px;
            margin: 0 0 22px 0;
            box-shadow: 0 8px 24px rgba(245, 158, 11, 0.25);
            position: relative;
            overflow: hidden;
        }

        .page-header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
            border-radius: 50%;
        }

        .page-header-content {
            position: relative;
            z-index: 1;
        }

        .page-header h1 {
            color: white;
            font-size: 36px;
            font-weight: 800;
            margin: 0 0 12px 0;
            letter-spacing: 0.5px;
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .page-header h1 svg {
            width: 42px;
            height: 42px;
        }

        .page-header .product-subtitle {
            color: rgba(255, 255, 255, 0.95);
            font-size: 16px;
            margin: 0 0 16px 0;
            font-weight: 600;
        }

        .page-header .breadcrumb {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            color: rgba(255, 255, 255, 0.9);
        }

        .page-header .breadcrumb a {
            color: white;
            text-decoration: none;
            transition: opacity 0.2s;
            font-weight: 600;
        }

        .page-header .breadcrumb a:hover {
            opacity: 0.8;
        }

        .page-header .breadcrumb svg {
            width: 14px;
            height: 14px;
        }

        /* Content Grid */
        .content-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 22px;
            margin: 0 24px;
        }

        /* Service Details Card */
        .details-card {
            background: linear-gradient(135deg, #ffffff 0%, #fffbeb 100%);
            border: 2px solid #fde68a;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(245, 158, 11, 0.1);
        }

        .details-card-header {
            background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
            padding: 20px 28px;
            border-bottom: 2px solid #fbbf24;
        }

        .details-card-header h2 {
            font-size: 22px;
            font-weight: 700;
            color: #92400e;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .details-card-header h2 svg {
            width: 24px;
            height: 24px;
            color: #f59e0b;
        }

        .details-table {
            width: 100%;
        }

        .details-row {
            display: grid;
            grid-template-columns: 200px 1fr;
            border-bottom: 1px solid #fef3c7;
            transition: background 0.2s ease;
        }

        .details-row:hover {
            background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
        }

        .details-row:last-child {
            border-bottom: none;
        }

        .details-label {
            padding: 24px 32px;
            font-size: 14px;
            font-weight: 700;
            color: #92400e;
            background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
            display: flex;
            align-items: center;
            gap: 10px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .details-label svg {
            width: 18px;
            height: 18px;
            color: #f59e0b;
        }

        .details-value {
            padding: 24px 32px;
            font-size: 16px;
            color: #78350f;
            font-weight: 600;
            display: flex;
            align-items: center;
        }

        .details-value.price {
            font-size: 28px;
            font-weight: 800;
            color: #ea580c;
        }

        .details-value.product-id {
            font-family: 'Courier New', monospace;
            color: #f59e0b;
            font-size: 18px;
        }

        /* Sidebar */
        .sidebar {
            display: flex;
            flex-direction: column;
            gap: 20px;
            align-items: stretch;
        }

        /* Action Card */
        .action-card {
            background: white;
            border: 2px solid #fed7aa;
            border-radius: 12px;
            padding: 24px;
            transition: all 0.3s ease;
        }

        .action-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(245, 158, 11, 0.15);
            border-color: #fbbf24;
        }

        .action-card h3 {
            font-size: 16px;
            font-weight: 700;
            color: #92400e;
            margin: 0 0 16px 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .action-card h3 svg {
            width: 20px;
            height: 20px;
            color: #f59e0b;
        }

        .action-buttons {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        /* Button Styles */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 14px 24px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.3s ease;
            letter-spacing: 0.3px;
            border: none;
            cursor: pointer;
            width: 100%;
        }

        .btn svg {
            width: 18px;
            height: 18px;
        }

        .btn-back {
            background: white;
            color: #ea580c;
            border: 2px solid #fde68a;
        }

        .btn-back:hover {
            background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
            border-color: #fbbf24;
            transform: translateY(-2px);
            color: #ea580c;
        }

        .btn-edit {
            background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%);
            color: white;
            box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);
        }

        .btn-edit:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(245, 158, 11, 0.4);
            background: linear-gradient(135deg, #fb923c 0%, #f97316 100%);
            color: white;
        }

        /* Info Card */
        .info-card {
            background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
            border: 2px solid #93c5fd;
            border-radius: 12px;
            padding: 20px;
        }

        .info-card-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 12px;
        }

        .info-card-header svg {
            width: 20px;
            height: 20px;
            color: #1e40af;
        }

        .info-card-header h4 {
            font-size: 14px;
            font-weight: 700;
            color: #1e40af;
            margin: 0;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .info-card p {
            font-size: 13px;
            color: #1e3a8a;
            margin: 0;
            line-height: 1.6;
        }

        /* Stats Card */
        .stats-card {
            background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
            border: 2px solid #fde68a;
            border-radius: 12px;
            padding: 24px;
        }

        .stats-card h3 {
            font-size: 16px;
            font-weight: 700;
            color: #92400e;
            margin: 0 0 16px 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .stats-card h3 svg {
            width: 20px;
            height: 20px;
            color: #f59e0b;
        }

        .stat-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid #fde68a;
        }

        .stat-item:last-child {
            border-bottom: none;
        }

        .stat-label {
            font-size: 13px;
            color: #92400e;
            font-weight: 600;
        }

        .stat-value {
            font-size: 15px;
            color: #ea580c;
            font-weight: 700;
        }

        /* Delete Section */
        .delete-card {
            background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
            border: 2px solid #fed7aa;
            border-radius: 12px;
            padding: 24px;
        }

        .delete-card h3 {
            font-size: 16px;
            font-weight: 700;
            color: #c2410c;
            margin: 0 0 12px 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .delete-card h3 svg {
            width: 20px;
            height: 20px;
        }

        .delete-card p {
            font-size: 13px;
            color: #9a3412;
            margin: 0 0 16px 0;
            line-height: 1.6;
        }

        .alert-warning {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
            border: 2px solid #fbbf24;
            color: #92400e;
            padding: 12px 16px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 16px;
        }

        .alert-warning svg {
            width: 18px;
            height: 18px;
            flex-shrink: 0;
            margin-top: 2px;
        }

        /* Badge */
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 14px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 0.3px;
        }

        .badge-id {
            background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
            color: #92400e;
            border: 2px solid #fbbf24;
        }

        .badge-status {
            background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%);
            color: #166534;
            border: 2px solid #86efac;
        }

        .badge-status svg {
            width: 14px;
            height: 14px;
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .content-grid {
                grid-template-columns: 1fr;
            }

            .details-row {
                grid-template-columns: 1fr;
            }

            .details-label {
                border-bottom: none;
            }
        }

        @media (max-width: 768px) {
            .page-container { padding: 16px; }

            .page-header { padding: 20px; margin: 0 8px 16px 8px; }

            .page-header h1 {
                font-size: 28px;
            }

            .content-grid { margin: 0 8px; }
            .details-card-header,
            .details-label,
            .details-value { padding: 16px 20px; }
        }
    </style>
{% endblock %}

{% block content %}
    <div class="page-container" style="padding: 0 56px 48px 56px;">
        {# Page Header #}
        <div class="page-header">
            <div class="page-header-content">
                <h1>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 7h-9M14 17H5"></path>
                        <circle cx="17" cy="17" r="3"></circle>
                        <circle cx="7" cy="7" r="3"></circle>
                    </svg>
                    {{ product.name }}
                </h1>
                <p class="product-subtitle">Product ID: #{{ product.id }}</p>
                <div class="breadcrumb">
                    <a href="{{ path('app_product_index') }}">Products</a>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="9 18 15 12 9 6"></polyline>
                    </svg>
                    <span>{{ product.name }}</span>
                </div>
            </div>
        </div>

        {# Content Grid #}
        <div class="content-grid">
            {# Service Details Card #}
            <div class="details-card">
                <div class="details-card-header">
                    <h2>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                            <line x1="16" y1="13" x2="8" y2="13"></line>
                            <line x1="16" y1="17" x2="8" y2="17"></line>
                            <polyline points="10 9 9 9 8 9"></polyline>
                        </svg>
                        Service Details
                    </h2>
                </div>

                <div class="details-table">
                    <div class="details-row">
                        <div class="details-label">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M10 13a5 5 0 007 0M12 2a7 7 0 00-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 00-7-7z"></path>
                            </svg>
                            Product ID
                        </div>
                        <div class="details-value product-id">
                            <span class="badge badge-id">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M10 13a5 5 0 007 0"></path>
                                    <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
                                </svg>
                                #{{ product.id }}
                            </span>
                        </div>
                    </div>

                    <div class="details-row">
                        <div class="details-label">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"></path>
                                <circle cx="12" cy="7" r="4"></circle>
                            </svg>
                            Product Name
                        </div>
                        <div class="details-value">
                            {{ product.name }}
                        </div>
                    </div>

                    <div class="details-row">
                        <div class="details-label">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"></circle>
                                <line x1="12" y1="16" x2="12" y2="12"></line>
                                <line x1="12" y1="8" x2="12.01" y2="8"></line>
                            </svg>
                            Issue
                        </div>
                        <div class="details-value">
                            {{ product.issue }}
                        </div>
                    </div>

                    <div class="details-row">
                        <div class="details-label">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="12" y1="1" x2="12" y2="23"></line>
                                <path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"></path>
                            </svg>
                            Price
                        </div>
                        <div class="details-value price">
                            ₱{{ product.price|number_format(2) }}
                        </div>
                    </div>

                    <div class="details-row">
                        <div class="details-label">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                <polyline points="22 4 12 14.01 9 11.01"></polyline>
                            </svg>
                            Status
                        </div>
                        <div class="details-value">
                            <span class="badge badge-status">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <polyline points="12 6 12 12 16 14"></polyline>
                                </svg>
                                Active
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            {# Sidebar #}
            <aside class="sidebar">
                {# Quick Actions Card #}
                <div class="action-card">
                    <h3>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="3"></circle>
                            <path d="M12 1v6m0 6v6"></path>
                            <path d="M17 7l-10 10M7 7l10 10"></path>
                        </svg>
                        Quick Actions
                    </h3>
                    <div class="action-buttons">
                        <a href="javascript:history.back()" class="btn btn-back">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="19" y1="12" x2="5" y2="12"></line>
                                <polyline points="12 19 5 12 12 5"></polyline>
                            </svg>
                            Back
                        </a>
                        {# Both staff and admin can edit all products #}
                        {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_STAFF') %}
                        <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="btn btn-edit">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"></path>
                                <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                            </svg>
                            Edit Product
                        </a>
                        {% endif %}
                    </div>
                </div>

                {# Info Card #}
                <div class="info-card">
                    <div class="info-card-header">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <path d="M12 16v-4M12 8h.01"></path>
                        </svg>
                        <h4>Information</h4>
                    </div>
                    <p>You can edit this product information at any time by clicking the "Edit Product" button above.</p>
                </div>

                {# Delete Card - Visible to both admin and staff users #}
                {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_STAFF') %}
                <div class="delete-card">
                    <h3>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"></path>
                        </svg>
                        Danger Zone
                    </h3>
                    <p>Permanently delete this product from your inventory.</p>
                    
                    <div class="alert-warning">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"></path>
                            <line x1="12" y1="9" x2="12" y2="13"></line>
                            <line x1="12" y1="17" x2="12.01" y2="17"></line>
                        </svg>
                        <span>This action cannot be undone.</span>
                    </div>
                    
                    {{ include('product/_delete_form.html.twig') }}
                </div>
                {% endif %}
            </aside>
        </div>
    </div>
{% endblock %}
