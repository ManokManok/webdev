{# templates/product/edit.html.twig #}
{% extends 'product/base.html.twig' %}

{% block title %}Edit Service{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Page Container */
        .page-container {
            max-width: 100%;
            margin: 0;
            padding: 0;
        }

        /* Page Header */
        .page-header {
            background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%);
            padding: 24px 32px;
            border-radius: 16px;
            margin: 0 0 20px 0;
            box-shadow: 0 8px 24px rgba(245, 158, 11, 0.25);
            position: relative;
            overflow: hidden;
        }

        .page-header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
            border-radius: 50%;
        }

        .page-header h1 {
            color: white;
            font-size: 32px;
            font-weight: 800;
            margin: 0;
            position: relative;
            z-index: 1;
            letter-spacing: 0.5px;
        }

        .page-header .breadcrumb {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-top: 12px;
            font-size: 14px;
            color: rgba(255, 255, 255, 0.9);
            position: relative;
            z-index: 1;
        }

        .page-header .breadcrumb a {
            color: white;
            text-decoration: none;
            transition: opacity 0.2s;
        }

        .page-header .breadcrumb a:hover {
            opacity: 0.8;
        }

        .page-header .breadcrumb svg {
            width: 14px;
            height: 14px;
        }

        /* Content Grid */
        .content-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 20px;
            margin: 0;
        }

        /* Form Card */
        .form-card {
            background: linear-gradient(135deg, #ffffff 0%, #fffbeb 100%);
            border: 2px solid #fde68a;
            border-radius: 16px;
            padding: 28px 32px;
            box-shadow: 0 4px 20px rgba(245, 158, 11, 0.1);
        }

        .form-card h2 {
            font-size: 20px;
            font-weight: 700;
            color: #92400e;
            margin-bottom: 24px;
            padding-bottom: 16px;
            border-bottom: 2px solid #fde68a;
        }

        /* Action Cards */
        .action-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-top: 24px;
        }

        .action-card {
            background: white;
            border: 2px solid #fed7aa;
            border-radius: 12px;
            padding: 24px;
            transition: all 0.3s ease;
        }

        .action-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(245, 158, 11, 0.15);
            border-color: #fbbf24;
        }

        .action-card h3 {
            font-size: 16px;
            font-weight: 700;
            color: #92400e;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .action-card h3 svg {
            width: 20px;
            height: 20px;
            color: #f59e0b;
        }

        .action-card p {
            font-size: 14px;
            color: #b45309;
            margin-bottom: 16px;
            line-height: 1.6;
        }

        /* Back Link Button */
        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: white;
            color: #ea580c;
            border: 2px solid #fde68a;
            padding: 12px 24px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.3s ease;
            letter-spacing: 0.3px;
        }

        .btn-back:hover {
            background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
            border-color: #fbbf24;
            transform: translateX(-4px);
            color: #ea580c;
        }

        .btn-back svg {
            width: 16px;
            height: 16px;
        }

        /* Delete Section */
        .delete-section {
            background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
            border: 2px solid #fed7aa;
            border-radius: 12px;
            padding: 24px;
            margin-top: 24px;
        }

        .delete-section h3 {
            font-size: 16px;
            font-weight: 700;
            color: #c2410c;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .delete-section h3 svg {
            width: 20px;
            height: 20px;
        }

        .delete-section p {
            font-size: 14px;
            color: #9a3412;
            margin-bottom: 16px;
            line-height: 1.6;
        }

        /* Alert Box */
        .alert {
            padding: 16px 20px;
            border-radius: 10px;
            margin-bottom: 24px;
            display: flex;
            align-items: flex-start;
            gap: 12px;
            font-size: 14px;
            font-weight: 600;
        }

        .alert svg {
            width: 20px;
            height: 20px;
            flex-shrink: 0;
            margin-top: 2px;
        }

        .alert-warning {
            background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
            border: 2px solid #fbbf24;
            color: #92400e;
        }

        .alert-info {
            background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
            border: 2px solid #93c5fd;
            color: #1e40af;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .page-container { padding: 16px; }

            .page-header { padding: 20px; margin: 0 8px 16px 8px; }

            .page-header h1 {
                font-size: 24px;
            }

            .form-card {
                padding: 24px;
            }

            .action-cards {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block content %}
    <div class="page-container" style="padding: 0 56px 48px 56px;">
        {# Page Header #}
        <div class="page-header">
            <h1>✏️ Edit Service</h1>
            <div class="breadcrumb">
                <a href="{{ path('app_product_index') }}">Products</a>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
                <span>Edit</span>
            </div>
        </div>

        {# Optional: Info Alert #}
        <div class="alert alert-info">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="16" x2="12" y2="12"></line>
                <line x1="12" y1="8" x2="12.01" y2="8"></line>
            </svg>
            <span>Make changes to your product information below. All fields marked with * are required.</span>
        </div>

        {# Main Content Grid #}
        <div class="content-grid">
            {# Form Card #}
            <div class="form-card">
                <h2>📦 Service Information</h2>
                {{ include('product/_form.html.twig', {'button_label': 'Update Product', 'form_action': path('app_product_edit', {'id': product.id})}) }}
            </div>
        </div>
    </div>
{% endblock %}