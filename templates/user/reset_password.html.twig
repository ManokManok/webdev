{% extends 'admin/base.html.twig' %}

{% block title %}Reset Password - {{ user.username }}{% endblock %}

{% block stylesheets %}
<style>
:root {
    --primary-color: #f59e0b;
    --primary-dark: #ea580c;
    --border-color: #e5e7eb;
}
.admin-page-header {
    background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
    padding: 32px 40px;
    border-radius: 16px;
    margin-bottom: 32px;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    color: white;
}
.admin-page-header h1 {
    margin: 0;
    font-size: 32px;
    font-weight: 700;
}
.admin-card {
    background: white;
    border-radius: 16px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    border: 1px solid var(--border-color);
}
.admin-card-body {
    padding: 32px;
}
.form-control {
    border: 2px solid var(--border-color);
    border-radius: 10px;
    padding: 12px 16px;
    font-size: 15px;
    transition: all 0.3s ease;
}
.form-control:focus {
    border-color: var(--primary-color);
    box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.1);
    outline: none;
}
.btn-admin-primary {
    background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
    border: none;
    color: white;
    padding: 12px 24px;
    border-radius: 8px;
    font-weight: 600;
    transition: all 0.3s ease;
}
.btn-admin-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(245, 158, 11, 0.4);
    color: white;
}
.btn-admin-outline {
    border: 2px solid var(--border-color);
    background: white;
    padding: 12px 24px;
    border-radius: 8px;
    font-weight: 500;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
}
</style>
{% endblock %}

{% block content %}
<div style="padding: 0 48px 40px 48px;">
    <div class="admin-page-header">
        <div>
            <h1>
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16" style="display: inline-block; margin-right: 12px; vertical-align: middle;">
                    <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2zM5 8h6a1 1 0 0 1 1 1v5a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V9a1 1 0 0 1 1-1z"/>
                </svg>
                Reset Password for {{ user.username }}
            </h1>
            <p>Set a new password for this user account</p>
        </div>
    </div>

    <div class="admin-card">
        <div class="admin-card-body">
            {{ form_start(form) }}
                <div class="mb-4">
                    {{ form_label(form.plainPassword.first, null, {'label_attr': {'class': 'form-label', 'style': 'font-weight: 600; margin-bottom: 8px; display: block;'}}) }}
                    {{ form_widget(form.plainPassword.first, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.plainPassword.first) }}
                </div>
                <div class="mb-4">
                    {{ form_label(form.plainPassword.second, null, {'label_attr': {'class': 'form-label', 'style': 'font-weight: 600; margin-bottom: 8px; display: block;'}}) }}
                    {{ form_widget(form.plainPassword.second, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.plainPassword.second) }}
                </div>
                <div class="d-flex gap-2" style="margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--border-color);">
                    <button type="submit" class="btn-admin-primary">Reset Password</button>
                    <a href="{{ path('app_user_index') }}" class="btn-admin-outline">Cancel</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
