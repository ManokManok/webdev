{% extends 'admin/base.html.twig' %}

{% block title %}User Details{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="{{ asset('templates/admin/admin_styles.css') }}">
{% endblock %}

{% block content %}
<div style="padding: 0 48px 40px 48px;">
    <div class="admin-page-header">
        <div>
            <h1>
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16" style="display: inline-block; margin-right: 12px;">
                    <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                    <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                </svg>
                User Details
            </h1>
            <p>View and manage user account information</p>
        </div>
        <a href="{{ path('app_user_index') }}" class="btn-admin-outline">Back to List</a>
    </div>

    <div class="admin-card">
        <div class="admin-card-body">
            <table class="table-admin" style="border: none;">
                <tbody>
                    <tr>
                        <th style="width: 200px; background: var(--light-bg);">Name</th>
                        <td><strong>{{ user.username }}</strong></td>
                    </tr>
                    <tr>
                        <th style="background: var(--light-bg);">Email</th>
                        <td>{{ user.email }}</td>
                    </tr>
                    <tr>
                        <th style="background: var(--light-bg);">Role</th>
                        <td>
                            {% if 'ROLE_ADMIN' in user.roles %}
                                <span class="badge-admin badge-danger">Admin</span>
                            {% elseif 'ROLE_STAFF' in user.roles %}
                                <span class="badge-admin badge-primary">Staff</span>
                            {% else %}
                                <span class="badge-admin badge-secondary">User</span>
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <th style="background: var(--light-bg);">Status</th>
                        <td>
                            {% if user.isActive %}
                                <span class="badge-admin badge-success">Active</span>
                            {% else %}
                                <span class="badge-admin badge-secondary">Inactive</span>
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <th style="background: var(--light-bg);">Date Created</th>
                        <td>{{ user.createdAt ? user.createdAt|date('F d, Y \a\t H:i') : '-' }}</td>
                    </tr>
                </tbody>
            </table>
            <div class="d-flex gap-2" style="margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--border-color);">
                <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn-admin-primary">Edit User</a>
                <a href="{{ path('app_user_reset_password', {'id': user.id}) }}" class="btn-admin-outline" style="border-color: var(--warning-color); color: var(--warning-color);">Reset Password</a>
                <form method="post" action="{{ path('app_user_toggle_status', {'id': user.id}) }}" class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ user.id) }}">
                    <button type="submit" class="btn-admin-outline" style="border-color: {{ user.isActive ? 'var(--text-secondary)' : 'var(--success-color)' }}; color: {{ user.isActive ? 'var(--text-secondary)' : 'var(--success-color)' }};">
                        {{ user.isActive ? 'Disable' : 'Enable' }}
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
