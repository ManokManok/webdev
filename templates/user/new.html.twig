{% extends 'admin/base.html.twig' %}

{% block title %}Create New User{% endblock %}

{% block content %}
<section class="hero">
    <div class="widgets">
        <div class="widget table" style="grid-column: 1 / -1;">
            <div class="widget-head">
                <div class="label">User Information</div>
            </div>
            <div style="padding: 0;">
                {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate', 'style': 'padding: 24px;'}}) }}
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                        <div>
                            <label style="display: block; font-weight: 600; color: #111827; margin-bottom: 8px; font-size: 14px;">
                                {{ form_label(form.username) }}
                            </label>
                            {{ form_widget(form.username, {'attr': {'class': 'form-control-admin', 'style': 'width: 100%; padding: 12px 16px; border: 2px solid #e5e7eb; border-radius: 10px; font-size: 15px; transition: all 0.3s ease;'}}) }}
                            {{ form_errors(form.username) }}
                        </div>
                        <div>
                            <label style="display: block; font-weight: 600; color: #111827; margin-bottom: 8px; font-size: 14px;">
                                {{ form_label(form.email) }}
                            </label>
                            {{ form_widget(form.email, {'attr': {'class': 'form-control-admin', 'style': 'width: 100%; padding: 12px 16px; border: 2px solid #e5e7eb; border-radius: 10px; font-size: 15px; transition: all 0.3s ease;'}}) }}
                            {{ form_errors(form.email) }}
                        </div>
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                        <div>
                            <label style="display: block; font-weight: 600; color: #111827; margin-bottom: 8px; font-size: 14px;">
                                {{ form_label(form.roles) }}
                            </label>
                            {{ form_widget(form.roles, {'attr': {'class': 'form-control-admin', 'style': 'width: 100%; padding: 12px 16px; border: 2px solid #e5e7eb; border-radius: 10px; font-size: 15px; transition: all 0.3s ease;'}}) }}
                            {{ form_errors(form.roles) }}
                        </div>
                        <div>
                            <label style="display: block; font-weight: 600; color: #111827; margin-bottom: 8px; font-size: 14px;">
                                {{ form_label(form.plainPassword) }}
                            </label>
                            {{ form_widget(form.plainPassword, {'attr': {'class': 'form-control-admin', 'style': 'width: 100%; padding: 12px 16px; border: 2px solid #e5e7eb; border-radius: 10px; font-size: 15px; transition: all 0.3s ease;'}}) }}
                            {{ form_errors(form.plainPassword) }}
                        </div>
                    </div>
                    <div style="margin-bottom: 24px; padding: 16px; background: #f8fafc; border-radius: 10px; border: 2px solid #e5e7eb;">
                        <div style="display: flex; align-items: center; gap: 12px;">
                            {{ form_widget(form.isActive, {'attr': {'class': 'form-check-input', 'style': 'width: 20px; height: 20px; cursor: pointer;'}}) }}
                            <label style="font-weight: 600; color: #111827; margin: 0; cursor: pointer;">
                                {{ form_label(form.isActive) }}
                            </label>
                        </div>
                        {{ form_errors(form.isActive) }}
                    </div>
                    <div style="display: flex; gap: 12px; padding-top: 20px; border-top: 2px solid #e5e7eb;">
                        <button type="submit" class="btn-admin-primary" style="background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%); border: none; color: white; padding: 12px 24px; border-radius: 8px; font-weight: 600; transition: all 0.3s ease; cursor: pointer; flex: 1;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16" style="display: inline-block; margin-right: 6px; vertical-align: middle;">
                                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                                <path d="M10.97 4.97a.75.75 0 0 0-1.08 1.05l-3.99 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 0-1.06 1.06l2.094 2.093a.75.75 0 0 0 1.08-.022l3.99-4.99a.75.75 0 0 0-.018-1.06z"/>
                            </svg>
                            Create User
                        </button>
                        <a href="{{ path('app_user_index') }}" class="btn-admin-outline" style="border: 2px solid #e5e7eb; background: white; padding: 12px 24px; border-radius: 8px; font-weight: 500; transition: all 0.3s ease; text-decoration: none; display: inline-flex; align-items: center; justify-content: center;">
                            Cancel
                        </a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</section>

<style>
.form-control-admin:focus {
    border-color: #f59e0b;
    box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.1);
    outline: none;
}
.btn-admin-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(245, 158, 11, 0.4);
    color: white;
}
.btn-admin-outline:hover {
    background: #f8fafc;
    border-color: #f59e0b;
}
</style>
{% endblock %}
