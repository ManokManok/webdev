  <body>

  <!-- ════ HEADER ════ -->
  <header class="hdr">
    <div class="hdr-logo" onclick="go('home')">
      <div class="logo-mark"><i data-feather="settings"></i></div>
      <div class="logo-text">
        <div class="ln">Onin's</div>
        <div class="ls">Smartphone Repair & Service</div>
      </div>
    </div>
    <nav>
      <ul class="hdr-nav">
        <li><button onclick="go('home')" id="nb-home" class="act">Home</button></li>
        <li><button onclick="go('about')" id="nb-about">About Us</button></li>
        <li><button onclick="go('services')" id="nb-services">Services</button></li>
        <li><button onclick="go('contact')" id="nb-contact">Contact Us</button></li>
        <li>
          {% if app.user %}
          <form method="post" action="{{ path('app_logout') }}" style="display:inline;margin:0;padding:0;">
            <button type="submit" class="hdr-cta">Sign Out →</button>
          </form>
          {% else %}
          <button class="hdr-cta" onclick="openLoginModal()">Sign In</button>
          {% endif %}
        </li>
      </ul>
    </nav>
  </header>

  <!-- ══════════════════════════════
      HOME
  ══════════════════════════════ -->
  <div class="page active" id="pg-home">
    <section class="hero">
      <img class="hero-bg-img" src="https://images.unsplash.com/photo-1611532736597-de2d4265fba3?w=1600&q=80&auto=format&fit=crop" alt="smartphone repair workshop">
      <div class="hero-over"></div>
      <div class="hero-dots"></div>
      <div class="hero-shapes"><div class="hs hs1"></div><div class="hs hs2"></div><div class="hs hs3"></div></div>
      <div class="hero-inner">
        <div>
          <div class="hero-badge"><span class="bd"></span> Cebu's #1 Trusted Repair Shop</div>
          <h1 class="hero-title">Your device.<br>Fixed <em>right.</em><br>Fixed fast.</h1>
          <p class="hero-desc">Certified technicians, genuine parts, and transparent pricing — restoring your smartphone to perfect condition. Most repairs done same day.</p>
          <div class="hero-trust">
            <div class="ht-faces">
              <div class="ht-face">J</div><div class="ht-face">M</div><div class="ht-face">A</div><div class="ht-face">+</div>
            </div>
            <div class="ht-text">
              <strong>2,400+ happy customers</strong>
              <span>★★★★★ 4.9 average rating</span>
            </div>
          </div>
        </div>
        <div class="hero-vis">
          <div class="orb orb1"></div><div class="orb orb2"></div>
          <div class="phone-card">
            <div class="ph-img-wrap">
              <img src="https://images.unsplash.com/photo-1601784551446-20c9e07cdbdb?w=400&q=80&auto=format&fit=crop" alt="phone screen repair">
              <div class="ph-label">REPAIR LIVE STATUS</div>
            </div>
            <div class="ph-body">
              <div class="ph-chip"><div class="pc-lbl">Current Status</div><div class="pc-val">In Progress</div><div class="pc-sub">Est. 45 mins remaining</div></div>
