<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>Onin's Smartphone Repair & Services</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&display=swap" rel="stylesheet">
		<link rel="stylesheet" href="{{ asset('css/landingpage.css') }}">
	</head>
	<body>

		<!-- ════ HEADER ════ -->
		<header class="hdr">
			<div class="hdr-logo" onclick="go('home')">
				<div class="logo-mark" style="color: #f8f7f6;">
					<i data-feather="settings"></i>
				</div>
				<div class="logo-text">
					<div class="ln">Onin's</div>
					<div class="ls">Smartphone Repair & Service</div>
				</div>
			</div>

			<button class="burger-toggle" id="menuToggle" aria-label="Toggle Menu">
				<i data-feather="menu"></i>
			</button>

			<nav class="nav-container" id="navContainer">
				<ul class="hdr-nav">
					<li>
						<button onclick="go('home')" id="nb-home" class="act">Home</button>
					</li>
					<li>
						<button onclick="go('about')" id="nb-about">About Us</button>
					</li>
					<li>
						<button onclick="go('services')" id="nb-services">Services</button>
					</li>
					<li>
						<button onclick="go('contact')" id="nb-contact">Contact Us</button>
					</li>
					<li>
						{% if app.user %}
							<form method="post" action="{{ path('app_logout') }}" style="display:inline;margin:0;padding:0;">
								<button type="submit" class="hdr-cta">Sign Out →</button>
							</form>
						{% else %}
							<a href="{{ path('app_login') }}" class="hdr-cta" style="text-decoration: none; margin-left: 10px;">Join us now</a>
						{% endif %}
					</li>
				</ul>
			</nav>
		</header>

		{% include 'home/home.html.twig' %}
		{% include 'home/about.html.twig' %}
		{% include 'home/services.html.twig' %}
		{% include 'home/contact.html.twig' %}

		<!-- ════ FOOTER ════ -->
		<footer class="ftr">
			<div class="ftr-inner">
				<div class="ftr-top">
					<div class="ftr-brand">
						<div class="hdr-logo ftr-logo" onclick="go('home')" style="cursor:pointer;">
							<div class="logo-mark">
								<i data-feather="settings" style="color: #fff;"></i>
							</div>
							<div class="logo-text">
								<div class="ln">Onin's</div>
								<div class="ls">Smartphone Repair & Service</div>
							</div>
						</div>
						<p>Cebu's trusted smartphone repair specialists. Certified technicians, premium parts, and every repair backed by a 90-day warranty.</p>
						<div class="fsoc">
							<div class="fsoc-btn">
								<i data-feather="facebook"></i>
							</div>
							<div class="fsoc-btn">
								<i data-feather="camera"></i>
							</div>
							<div class="fsoc-btn">
								<i data-feather="twitter"></i>
							</div>
						</div>
					</div>
					<div class="ftr-links">
						<div class="fc-col">
							<h5>Company</h5>
							<ul>
								<li><a onclick="go('home')">Home</a></li>
								<li><a onclick="go('about')">About Us</a></li>
								<li><a onclick="go('contact')">Contact Us</a></li>
							</ul>
						</div>
						<div class="fc-col">
							<h5>Services</h5>
							<ul>
								<li><a onclick="go('services')">Screen Repair</a></li>
								<li><a onclick="go('services')">Battery Replacement</a></li>
								<li><a onclick="go('services')">Water Damage</a></li>
								<li><a onclick="go('services')">Software Issues</a></li>
								<li><a onclick="go('services')">View Pricing</a></li>
							</ul>
						</div>
						<div class="fc-col">
							<h5>Support</h5>
							<ul>
								<li><a onclick="go('services')">Book a Repair</a></li>
								<li><a onclick="go('contact')">Get a Quote</a></li>
								<li><a onclick="go('services')">Warranty Info</a></li>
								<li><a onclick="go('about')">Our Team</a></li>
							</ul>
						</div>
					</div>
				</div>
				<div class="ftr-bot">
					<span class="ftr-copy">© 2025 Onin's Smartphone Repair & Service. All rights reserved.</span>
					<div class="ftr-legal">
						<a href="#">Privacy Policy</a>
						<a href="#">Terms of Service</a>
					</div>
				</div>
			</div>
		</footer>

		<!-- ════ BOOKING MODAL ════ -->
		<div class="booking-overlay" id="bookingOverlay" onclick="closeBookingOnBg(event)">
			<div class="booking-modal" id="bookingModal">
				<div class="bm-header">
					<button class="bm-close" onclick="closeBooking()">×</button>
					<div class="bm-service-badge" id="bm-badge">
						<i data-feather="settings"></i>
						Book a Repair</div>
					<div class="bm-header-icon" id="bm-icon">
						<i data-feather="smartphone"></i>
					</div>
					<h2 id="bm-title">Book Your Repair</h2>
					<p id="bm-subtitle">Fill in your details and we'll confirm within 1 hour.</p>
				</div>
				<div class="bm-progress">
					<div class="bm-step active" id="prog-1">
						<div class="bm-step-num">1</div>
						<div class="bm-step-label">Service</div>
					</div>
					<div class="bm-step-line" id="line-1"></div>
					<div class="bm-step" id="prog-2">
						<div class="bm-step-num">2</div>
						<div class="bm-step-label">Details</div>
					</div>
					<div class="bm-step-line" id="line-2"></div>
					<div class="bm-step" id="prog-3">
						<div class="bm-step-num">3</div>
						<div class="bm-step-label">Confirm</div>
					</div>
				</div>
				<div class="bm-body">
					<div class="bm-panel active" id="panel-1">
						<div class="bm-section-label">Choose Your Service</div>
						<div class="bm-services-grid" id="services-grid">
							<div class="bm-svc-chip" data-service="Screen Repair & Replacement" data-icon="smartphone" data-price="₱800–₱3,500" data-tag="Most Common" onclick="selectService(this)">
								<span class="bm-chip-icon">
									<i data-feather="smartphone"></i>
								</span>
								<div class="bm-chip-info">
									<strong>Screen Repair</strong>
									<span>₱800–₱3,500</span>
								</div>
							</div>
							<div class="bm-svc-chip" data-service="Battery Replacement" data-icon="battery" data-price="₱600–₱1,800" data-tag="Same Day" onclick="selectService(this)">
								<span class="bm-chip-icon">
									<i data-feather="battery"></i>
								</span>
								<div class="bm-chip-info">
									<strong>Battery Replacement</strong>
									<span>₱600–₱1,800</span>
								</div>
							</div>
							<div class="bm-svc-chip" data-service="Water Damage Repair" data-icon="droplet" data-price="₱500–₱2,000" data-tag="No fix, no fee" onclick="selectService(this)">
								<span class="bm-chip-icon">
									<i data-feather="droplet"></i>
								</span>
								<div class="bm-chip-info">
									<strong>Water Damage</strong>
									<span>₱500–₱2,000</span>
								</div>
							</div>
							<div class="bm-svc-chip" data-service="Software & OS Issues" data-icon="settings" data-price="₱300–₱800" data-tag="Quick Fix" onclick="selectService(this)">
								<span class="bm-chip-icon">
									<i data-feather="settings"></i>
								</span>
								<div class="bm-chip-info">
									<strong>Software Issues</strong>
									<span>₱300–₱800</span>
								</div>
							</div>
							<div class="bm-svc-chip" data-service="Camera Repair" data-icon="camera" data-price="₱600–₱2,500" data-tag="Specialist" onclick="selectService(this)">
								<span class="bm-chip-icon">
									<i data-feather="camera"></i>
								</span>
								<div class="bm-chip-info">
									<strong>Camera Repair</strong>
									<span>₱600–₱2,500</span>
								</div>
							</div>
							<div class="bm-svc-chip" data-service="Charging Port Repair" data-icon="power" data-price="₱400–₱1,200" data-tag="Affordable" onclick="selectService(this)">
								<span class="bm-chip-icon">
									<i data-feather="power"></i>
								</span>
								<div class="bm-chip-info">
									<strong>Charging Port</strong>
									<span>₱400–₱1,200</span>
								</div>
							</div>
						</div>
						<div class="bm-section-label">Preferred Date & Time</div>
						<div class="bm-row" style="margin-bottom:20px;">
							<div class="bm-field">
								<label>Preferred Date</label><input type="date" id="bm-date" min=""></div>
							<div class="bm-field">
								<label>Preferred Time</label>
								<select id="bm-time-select">
									<option value="">Select time...</option>
									<option>8:00 AM – 10:00 AM</option>
									<option>10:00 AM – 12:00 PM</option>
									<option>12:00 PM – 2:00 PM</option>
									<option>2:00 PM – 4:00 PM</option>
									<option>4:00 PM – 6:00 PM</option>
								</select>
							</div>
						</div>
						<div class="bm-footer">
							<button class="bm-btn-next" id="step1-next" onclick="goToStep(2)" disabled>Continue → Details</button>
						</div>
					</div>
					<div class="bm-panel" id="panel-2">
						<div class="bm-section-label">Your Information</div>
						<div class="bm-row">
							<div class="bm-field">
								<label>First Name</label><input type="text" id="bm-fname" placeholder="Juan"></div>
							<div class="bm-field">
								<label>Last Name</label><input type="text" id="bm-lname" placeholder="Dela Cruz"></div>
						</div>
						<div class="bm-row">
							<div class="bm-field">
								<label>Phone / Viber</label><input type="tel" id="bm-phone" placeholder="+63 900 000 0000"></div>
							<div class="bm-field">
								<label>Email (Optional)</label><input type="email" id="bm-email" placeholder="you@email.com"></div>
						</div>
						<div class="bm-section-label">Device Info</div>
						<div class="bm-row">
							<div class="bm-field">
								<label>Device Brand</label>
								<select id="bm-brand">
									<option value="">Select brand...</option>
									<option>Apple iPhone</option>
									<option>Samsung</option>
									<option>Huawei</option>
									<option>Oppo</option>
									<option>Vivo</option>
									<option>Xiaomi</option>
									<option>Realme</option>
									<option>OnePlus</option>
									<option>Nokia</option>
									<option>Other</option>
								</select>
							</div>
							<div class="bm-field">
								<label>Device Model</label><input type="text" id="bm-model" placeholder="e.g. iPhone 14, S23 Ultra"></div>
						</div>
						<div class="bm-field">
							<label>Describe the Issue</label>
							<textarea id="bm-issue" placeholder="Tell us more about what's happening with your device..."></textarea>
						</div>
						<div class="bm-footer">
							<button class="bm-btn-back" onclick="goToStep(1)">← Back</button>
							<button class="bm-btn-next" onclick="goToStep(3)">Review Booking →</button>
						</div>
					</div>
					<div class="bm-panel" id="panel-3">
						<div class="bm-section-label">Booking Summary</div>
						<div class="bm-review-card" id="bm-review">
							<div class="bm-review-row">
								<span class="label">Service</span>
								<span class="value" id="rev-service">—</span>
							</div>
							<div class="bm-review-row">
								<span class="label">Price Range</span>
								<span class="value" id="rev-price">—</span>
							</div>
							<div class="bm-review-row">
								<span class="label">Date & Time</span>
								<span class="value" id="rev-datetime">—</span>
							</div>
							<div class="bm-review-row">
								<span class="label">Name</span>
								<span class="value" id="rev-name">—</span>
							</div>
							<div class="bm-review-row">
								<span class="label">Phone</span>
								<span class="value" id="rev-phone">—</span>
							</div>
							<div class="bm-review-row">
								<span class="label">Device</span>
								<span class="value" id="rev-device">—</span>
							</div>
							<div class="bm-review-row">
								<span class="label">Issue</span>
								<span class="value" id="rev-issue">—</span>
							</div>
						</div>
						<p style="font-size:13px;color:var(--text3);line-height:1.6;margin-bottom:24px;">
							<i data-feather="clipboard"></i>
							Final pricing is confirmed after a
							<strong>free diagnostic</strong>. We'll contact you within 1 hour to confirm your appointment.</p>
						<div class="bm-footer">
							<button class="bm-btn-back" onclick="goToStep(2)">← Edit Details</button>
							<button class="bm-btn-next" onclick="confirmBooking()">✓ Confirm Booking</button>
						</div>
					</div>
					<div class="bm-panel" id="panel-success">
						<div class="bm-success">
							<div class="bm-success-icon">
								<i data-feather="check-circle" style="color:green;width:40px;height:40px;"></i>
							</div>
							<h3>Booking Confirmed!</h3>
							<p>Thank you! Your repair request has been received. Our team will call or message you within
								<strong>1 hour</strong>
								to confirm your appointment details.</p>
							<div class="bm-ref" id="bm-ref-num">ONR-000000</div>
							<p style="font-size:13px;color:var(--text3);margin-bottom:20px;">Save your reference number above. You can also check your booking status by contacting us.</p>
							<button class="bm-btn-next" onclick="closeBooking()" style="max-width:280px;">Back to Services</button>
						</div>
					</div>
				</div>
			</div>
		</div>

		<script src="{{ asset('js/homeindex.js') }}"></script>
		<!-- Feather Icons Library - Load at end for proper initialization -->
		<script src="{{ asset('vendor/feather-icons/feather.min.js') }}" defer></script>
		<script>
			/* Safe Feather Icons initialization with defer handling */
function renderIconsWhenReady() {
if (typeof feather !== 'undefined' && feather.replace) {
feather.replace();
} else {
setTimeout(renderIconsWhenReady, 50);
}
}

document.addEventListener('DOMContentLoaded', renderIconsWhenReady);
		</script>
		<script>
			const menuToggle = document.getElementById('menuToggle');
const navContainer = document.getElementById('navContainer');
const navButtons = document.querySelectorAll('.hdr-nav button');

function setBurgerFeatherIcon(name) {
menuToggle.innerHTML = '<i data-feather="' + name + '"></i>';
if (typeof feather !== 'undefined' && feather.replace) {
feather.replace();
}
}

menuToggle.addEventListener('click', () => {
navContainer.classList.toggle('open');
setBurgerFeatherIcon(navContainer.classList.contains('open') ? 'x' : 'menu');
});

navButtons.forEach(btn => {
btn.addEventListener('click', () => {
navContainer.classList.remove('open');
setBurgerFeatherIcon('menu');
});
});
		</script>
	</body>
</html>
