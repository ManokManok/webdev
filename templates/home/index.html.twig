      <div class="ph-hero-ov"></div>
      <div class="ph-hero-geo"><div class="geo-circ gc1"></div><div class="geo-circ gc2"></div><div class="geo-circ gc3"></div></div>
      <div class="ph-hero-inner">
        <div class="pill"><span class="pill-dot"></span>Our Story</div>
        <h1 class="stitle">Built on trust,<br>driven by <em>precision.</em></h1>
        <p class="sdesc">Years of experience, thousands of successful repairs, and a team that genuinely cares.</p>
      </div>
    </div>
    <section class="ab-story">
      <div class="ab-story-inner">
        <div class="ab-img-col">
          <div class="ab-img-main"><img src="https://images.unsplash.com/photo-1581092580497-e0d23cbdf1dc?w=800&q=80&auto=format&fit=crop" alt="technician repairing phone"></div>
          <div class="ab-img-badge"><div class="num">2,400+</div><div class="lbl">Devices Repaired</div></div>
        </div>
