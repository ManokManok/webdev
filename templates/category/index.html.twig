{% extends 'category/base.html.twig' %}

{% block title %}Categories
	{% if is_granted('ROLE_ADMIN') %}
		- Admin
	{% else %}
		- Staff
	{% endif %}
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<style>
		/* Page container */
		.page-container {
			max-width: 100%;
			margin: 0;
			padding: 24px;
		}

		/* Header */
		.page-header {
			border-radius: 16px;
			padding: 20px 24px;
			margin: 0 0 24px;
			display: flex;
			align-items: center;
			justify-content: space-between;
			box-shadow: 0 8px 24px rgba(245, 158, 11, 0.25);
			color: #fff;
		}

		.page-header h1 {
			color: #ea580c;
			font-size: 28px;

			margin: 0;
			font-weight: 800;
			letter-spacing: 0.5px;
			display: flex;
			align-items: center;
			gap: 12px;
		}

		.page-header svg {
			width: 28px;
			height: 28px;
		}

		.btn-admin {
			display: inline-flex;
			align-items: center;
			gap: 8px;
			background: #fff;
			color: #ea580c;
			font-weight: 700;
			text-decoration: none;
			border: 2px solid #fbbf24;
			border-radius: 10px;
			padding: 10px 16px;
			transition: all 0.2s ease;
		}

		.btn-admin:hover {
			background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
			color: #ea580c;
			transform: translateY(-1px);
			text-decoration: none;
		}

		/* Category cards */
		.category-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
			gap: 20px;
			margin-bottom: 24px;
		}

		.category-card {
			background: #fff;
			border: 1px solid #fde68a;
			border-radius: 16px;
			overflow: hidden;
			box-shadow: 0 4px 20px rgba(245, 158, 11, 0.1);
			transition: transform 0.2s ease, box-shadow 0.2s ease;
		}

		.category-card:hover {
			transform: translateY(-4px);
			box-shadow: 0 8px 24px rgba(245, 158, 11, 0.2);
		}

		.category-header {
			display: flex;
			align-items: center;
			justify-content: flex-start;
			gap: 16px;
			padding: 20px;
			border-bottom: 1px dashed #fde68a;
		}

		.category-header-left {
			display: flex;
			align-items: center;
			gap: 16px;
			flex: 1;
			min-width: 0;
		}

		.category-avatar {
			width: 50px;
			height: 50px;
			border-radius: 50%;
			background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%);
			color: white;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 20px;
			font-weight: 700;
			flex-shrink: 0;
		}

		.category-info {
			flex: 1;
			min-width: 0;
		}

		.category-header-right {
			display: flex;
			align-items: center;
			gap: 12px;
			flex-shrink: 0;
		}

		.category-name {
			margin: 0 0 4px;
			font-size: 18px;
			font-weight: 700;
			color: #1f2937;
			white-space: nowrap;
			overflow: hidden;
			text-overflow: ellipsis;
		}

		.category-status {
			display: inline-block;
			background: #ffedd5;
			color: #9a3412;
			border: 1px solid #fed7aa;
			border-radius: 20px;
			padding: 3px 10px;
			font-size: 12px;
			font-weight: 600;
		}

		.category-status.active {
			background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%);
			color: #166534;
			border-color: #86efac;
		}

		/* Hover dropdown for active services */
		.category-status-wrapper {
			position: relative;
			display: inline-block;
		}

		.category-status {
			cursor: pointer;
			transition: all 0.2s ease;
		}

		.category-status.active:hover {
			transform: scale(1.05);
			box-shadow: 0 2px 8px rgba(22, 101, 52, 0.2);
		}

		.services-dropdown {
			position: absolute;
			top: 100%;
			left: 0;
			margin-top: 8px;
			background: #ffffff;
			border: 1px solid #e5e7eb;
			border-radius: 12px;
			box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
			min-width: 280px;
			max-width: 400px;
			max-height: 400px;
			overflow-y: auto;
			z-index: 1000;
			opacity: 0;
			visibility: hidden;
			transform: translateY(-10px);
			transition: all 0.2s ease;
			padding: 12px 0;
		}

		.category-status-wrapper:hover .services-dropdown {
			opacity: 1;
			visibility: visible;
			transform: translateY(0);
		}

		.services-dropdown-header {
			padding: 8px 16px;
			border-bottom: 1px solid #e5e7eb;
			font-weight: 600;
			font-size: 13px;
			color: #374151;
			background: #f9fafb;
		}

		.services-dropdown-list {
			list-style: none;
			margin: 0;
			padding: 0;
		}

		.services-dropdown-item {
			padding: 0;
			border-bottom: 1px solid #f3f4f6;
		}

		.services-dropdown-item:last-child {
			border-bottom: none;
		}

		.services-dropdown-item-link {
			display: block;
			padding: 10px 16px;
			text-decoration: none;
			color: inherit;
			transition: all 0.2s ease;
		}

		.services-dropdown-item-link:hover {
			background: #f3f4f6;
			cursor: pointer;
		}

		.services-dropdown-item-link:hover .services-dropdown-item-name {
			color: #f59e0b;
		}

		.services-dropdown-item-name {
			font-weight: 600;
			color: #1f2937;
			font-size: 14px;
			margin-bottom: 4px;
			transition: color 0.2s ease;
		}

		.services-dropdown-item-issue {
			color: #6b7280;
			font-size: 12px;
			line-height: 1.4;
		}

		.services-dropdown-empty {
			padding: 16px;
			text-align: center;
			color: #9ca3af;
			font-size: 13px;
		}

		.services-dropdown::-webkit-scrollbar {
			width: 6px;
		}

		.services-dropdown::-webkit-scrollbar-track {
			background: #f3f4f6;
			border-radius: 3px;
		}

		.services-dropdown::-webkit-scrollbar-thumb {
			background: #d1d5db;
			border-radius: 3px;
		}

		.services-dropdown::-webkit-scrollbar-thumb:hover {
			background: #9ca3af;
		}

		.category-body {
			padding: 16px 20px;
		}

		.category-details {
			margin: 0;
			padding: 0;
			list-style: none;
		}

		.category-details li {
			position: relative;
			padding-left: 24px;
			margin-bottom: 8px;
			color: #4b5563;
			font-size: 14px;
			line-height: 1.5;
		}

		.category-details li:before {
			content: '•';
			position: absolute;
			left: 0;
			color: #f59e0b;
			font-weight: bold;
		}

		.category-footer {
			padding: 14px 20px;
			background: #fff7ed;
			border-top: 1px solid #fde68a;
			display: flex;
			justify-content: flex-end;
		}

		.btn-view {
			display: inline-flex;
			align-items: center;
			gap: 6px;
			background: #f59e0b;
			color: white;
			border: none;
			border-radius: 8px;
			padding: 8px 16px;
			font-size: 14px;
			font-weight: 600;
			text-decoration: none;
			transition: all 0.2s ease;
		}

		.btn-view:hover {
			background: #ea580c;
			color: white;
			transform: translateY(-1px);
		}

		.empty-state {
			grid-column: 1 / -1;
			text-align: center;
			padding: 40px 20px;
			color: #6b7280;
			background: #fff;
			border: 1px dashed #f3f4f6;
			border-radius: 12px;
		}

		.empty-state-icon {
			font-size: 48px;
			margin-bottom: 16px;
			color: #d1d5db;
		}

		.empty-state p {
			margin-top: 8px;
			color: #9ca3af;
		}

		@media(max-width: 768px) {
			.category-grid {
				grid-template-columns: 1fr;
			}

			.page-header {
				flex-direction: column;
				gap: 16px;
				text-align: center;
			}

			.brands-grid {
				grid-template-columns: repeat(2, 1fr);
				gap: 12px;
			}

			.brands-header h2 {
				font-size: 1.5rem;
			}
		}

		/* Brands Showcase Styles */
		.brands-showcase {
			grid-column: 1 / -1;
			background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
			border: 2px solid #fbbf24;
			border-radius: 20px;
			padding: 40px 32px;
			text-align: center;
			box-shadow: 0 8px 32px rgba(245, 158, 11, 0.15);
		}

		.brands-header {
			display: flex;
			align-items: center;
			justify-content: center;
			gap: 12px;
			margin-bottom: 12px;
			color: #92400e;
		}

		.brands-header svg {
			color: #f59e0b;
		}

		.brands-header h2 {
			margin: 0;
			font-size: 1.875rem;
			font-weight: 800;
			color: #92400e;
		}

		.brands-subtitle {
			color: #b45309;
			font-size: 1rem;
			margin-bottom: 32px;
			font-weight: 500;
		}

		.brands-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
			gap: 16px;
			max-width: 900px;
			margin: 0 auto;
		}

		.brand-card {
			background: #ffffff;
			border: 2px solid #fde68a;
			border-radius: 16px;
			padding: 16px 12px;
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 10px;
			transition: all 0.3s ease;
			cursor: pointer;
			box-shadow: 0 4px 12px rgba(245, 158, 11, 0.1);
			position: relative;
			z-index: 1;
			justify-content: center;
			font-size: 20px;
			font-weight: 800;
		}

		.brand-card:hover {
			transform: translateY(-4px);
			border-color: #f59e0b;
			box-shadow: 0 8px 24px rgba(245, 158, 11, 0.25);
			background: linear-gradient(135deg, #fffbeb 0%, #ffffff 100%);
			z-index: 100;
		}

		.brand-logo {
			width: 50px;
			height: 50px;
			border-radius: 50%;
			background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%);
			color: white;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 22px;
			font-weight: 800;
			box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);
		}

		.brand-name {
			font-weight: 700;
			color: #1f2937;
			font-size: 0.9375rem;
		}

		/* Tooltip Styles - Show Downwards */
		.brand-card::before {
			content: attr(data-tooltip);
			position: absolute;
			top: 100%;
			left: 50%;
			transform: translateX(-50%) translateY(8px);
			background: #1f2937;
			color: #ffffff;
			padding: 12px 16px;
			border-radius: 12px;
			font-size: 0.875rem;
			font-weight: 500;
			opacity: 0;
			visibility: hidden;
			transition: all 0.25s ease;
			z-index: 9999;
			box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
			max-width: 280px;
			min-width: 200px;
			width: max-content;
			text-align: center;
			line-height: 1.5;
			pointer-events: none;
			margin-top: 8px;
		}

		.brand-card::after {
			content: '';
			position: absolute;
			top: 100%;
			left: 50%;
			transform: translateX(-50%);
			border: 8px solid transparent;
			border-bottom-color: #1f2937;
			opacity: 0;
			visibility: hidden;
			transition: all 0.25s ease;
			z-index: 9999;
			margin-top: -8px;
		}

		.brand-card:hover::before,
		.brand-card:hover::after {
			opacity: 1;
			visibility: visible;
		}

		.brand-card:hover::before {
			transform: translateX(-50%) translateY(12px);
		}

		.brand-card:hover::after {
			transform: translateX(-50%) translateY(4px);
		}
	</style>
{% endblock %}

{% block content %}
	<div class="page-container">
		<div class="page-header">
			<h1>
				<svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
					<path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
				</svg>
				Categories
			</h1>
		</div>

		<div class="category-grid">
			{% for category in categories %}
				{% set cnt = countsByCategory[category.id]|default(0) %}
				{% if cnt == 0 %}
					{% set fallback = brandCounts[category.name|lower]|default(0) %}
					{% set cnt = fallback %}
				{% endif %}
				{% set topIssue = topIssueByCategory[category.id]|default(null) %}

				<div class="category-card">
					<div class="category-header">
						<div class="category-header-left">
							<div class="category-avatar">
								{{ category.name|first|upper }}
							</div>
							<div class="category-info">
								<h3 class="category-name" title="{{ category.name }}">{{ category.name }}</h3>
								<div class="category-status-wrapper">
									<span class="category-status {{ cnt > 0 ? 'active' : '' }}">
										{% if cnt > 0 %}
											Active ({{ cnt }})
										{% else %}
											Inactive
										{% endif %}
									</span>
									{% if cnt > 0 %}
										{% set categoryProducts = productsByCategory[category.id]|default([]) %}
										<div class="services-dropdown">
											<div class="services-dropdown-header">
												Active Services ({{ categoryProducts|length }})
											</div>
											{% if categoryProducts|length > 0 %}
												<ul class="services-dropdown-list">
													{% for product in categoryProducts %}
														<li class="services-dropdown-item">
															<a href="{{ path('app_product_show', {'id': product.id}) }}" class="services-dropdown-item-link">
																<div class="services-dropdown-item-name">{{ product.name }}</div>
																{% if product.issue %}
																	<div class="services-dropdown-item-issue">{{ product.issue|slice(0, 60) }}
																		{% if product.issue|length > 60 %}...
																		{% endif %}
																	</div>
																{% endif %}
															</a>
														</li>
													{% endfor %}
												</ul>
											{% else %}
												<div class="services-dropdown-empty">No services found</div>
											{% endif %}
										</div>
									{% endif %}
								</div>
							</div>
						</div>
					</div>
					<div class="category-body">
						<ul class="category-details">
							{% if topIssue %}
								<li>Top Issue:
									{{ topIssue.issue }}</li>
								<li>Issue Count:
									{{ topIssue.count }}</li>
							{% else %}
								<li>No issues reported</li>
							{% endif %}
							<li>Total Services:
								{{ cnt }}</li>
						</ul>
					</div>
				</div>
			{% else %}
				{# Brand Names Showcase - Brands We Serve #}
				<div class="brands-showcase">
					<div class="brands-header">
						<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M12 2L2 7l10 5 10-5-10-5z"></path>
							<path d="M2 17l10 5 10-5"></path>
							<path d="M2 12l10 5 10-5"></path>
						</svg>
						<h2>Brands We Serve</h2>
					</div>
					<p class="brands-subtitle">Professional repair services for all major smartphone brands</p>

					<div class="brands-grid">
						{% set brands = [
                        {name: 'Apple', url: 'https://cdn.simpleicons.org/apple/ea580c', desc: 'iPhone, iPad, MacBook repairs and services'},
                        {name: 'Asus', url: 'https://cdn.simpleicons.org/asus/ea580c', desc: 'ROG phones, Zenfone series repairs'},
                        {name: 'Huawei', url: 'https://cdn.simpleicons.org/huawei/ea580c', desc: 'P series, Mate series, Nova repairs'},
                        {name: 'Infinix', url: 'https://cdn.simpleicons.org/infinix/ea580c', desc: 'Note series, Hot series, Zero repairs'},
                        {name: 'Lenovo', url: 'https://cdn.simpleicons.org/lenovo/ea580c', desc: 'Legion phones, Motorola repairs'},
                        {name: 'Motorola', url: 'https://cdn.simpleicons.org/motorola/ea580c', desc: 'Edge series, G series, Razr repairs'},
                        {name: 'Nokia', url: 'https://cdn.simpleicons.org/nokia/ea580c', desc: 'Classic and smartphone repairs'},
                        {name: 'OnePlus', url: 'https://cdn.simpleicons.org/oneplus/ea580c', desc: 'Flagship and Nord series repairs'},
                        {name: 'OPPO', url: 'https://cdn.simpleicons.org/oppo/ea580c', desc: 'Find series, Reno series, A series repairs'},
                        {name: 'realme', url: 'https://cdn.simpleicons.org/realme/ea580c', desc: 'GT series, Number series, C series repairs'},
                        {name: 'Samsung', url: 'https://cdn.simpleicons.org/samsung/ea580c', desc: 'Galaxy S series, A series, Z Fold/Flip repairs'},
                        {name: 'Sony', url: 'https://cdn.simpleicons.org/sony/ea580c', desc: 'Xperia series repairs and services'},
                        {name: 'TECNO', url: 'https://cdn.simpleicons.org/tecno/ea580c', desc: 'Camon series, Spark series, Phantom repairs'},
                        {name: 'vivo', url: 'https://cdn.simpleicons.org/vivo/ea580c', desc: 'V series, Y series, X series repairs'},
                        {name: 'Xiaomi', url: 'https://cdn.simpleicons.org/xiaomi/ea580c', desc: 'Mi series, Redmi, POCO repairs'}
                    ] %}
						{% for brand in brands %}
							<div class="brand-card" data-tooltip="{{ brand.desc }}">
								<img loading="lazy" decoding="async" src="{{ brand.url }}" alt="{{ brand.name }} logo" class="brand-logo-img" onerror="this.style.display='none'; this.parentElement.querySelector('.brand-fallback').style.display='flex'">
								<div class="brand-fallback" style="display:none;">{{ brand.name|first|upper }}</div>
								<span class="brand-name">{{ brand.name }}</span>
							</div>
						{% endfor %}
					</div>
				</div>
			{% endfor %}
		</div>
	</div>
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script>
		// Add any category-specific JavaScript here
document.addEventListener('DOMContentLoaded', function () { // Initialize tooltips
var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
return new bootstrap.Tooltip(tooltipTriggerEl);
});
});
	</script>
{% endblock %}
