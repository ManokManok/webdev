{% extends 'category/base.html.twig' %}

{% block title %}Categories{% if is_granted('ROLE_ADMIN') %} - Admin{% else %} - Staff{% endif %}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Page container */
        .page-container {
            max-width: 100%;
            margin: 0;
            padding: 24px;
        }

        /* Header */
        .page-header {
            background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%);
            border-radius: 16px;
            padding: 20px 24px;
            margin: 0 0 24px 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 8px 24px rgba(245, 158, 11, 0.25);
            color: #fff;
        }
        
        .page-header h1 {
            margin: 0;
            font-weight: 800;
            letter-spacing: 0.5px;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .page-header h1 svg {
            width: 28px;
            height: 28px;
        }

        .btn-admin {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #fff;
            color: #ea580c;
            font-weight: 700;
            text-decoration: none;
            border: 2px solid #fbbf24;
            border-radius: 10px;
            padding: 10px 16px;
            transition: all 0.2s ease;
        }
        
        .btn-admin:hover {
            background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
            color: #ea580c;
            transform: translateY(-1px);
            text-decoration: none;
        }

        /* Category cards */
        .category-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 20px;
            margin-bottom: 24px;
        }
        
        .category-card {
            background: #fff;
            border: 1px solid #fde68a;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(245, 158, 11, 0.1);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        
        .category-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(245, 158, 11, 0.2);
        }
        
        .category-header {
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: 16px;
            padding: 20px;
            border-bottom: 1px dashed #fde68a;
        }
        
        .category-header-left {
            display: flex;
            align-items: center;
            gap: 16px;
            flex: 1;
            min-width: 0;
        }
        
        .category-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: 700;
            flex-shrink: 0;
        }
        
        .category-info {
            flex: 1;
            min-width: 0;
        }
        
        .category-header-right {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-shrink: 0;
        }
        
        .category-name {
            margin: 0 0 4px 0;
            font-size: 18px;
            font-weight: 700;
            color: #1f2937;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        
        .category-status {
            display: inline-block;
            background: #ffedd5;
            color: #9a3412;
            border: 1px solid #fed7aa;
            border-radius: 20px;
            padding: 3px 10px;
            font-size: 12px;
            font-weight: 600;
        }
        
        .category-status.active {
            background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%);
            color: #166534;
            border-color: #86efac;
        }

        /* Hover dropdown for active services */
        .category-status-wrapper {
            position: relative;
            display: inline-block;
        }

        .category-status {
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .category-status.active:hover {
            transform: scale(1.05);
            box-shadow: 0 2px 8px rgba(22, 101, 52, 0.2);
        }

        .services-dropdown {
            position: absolute;
            top: 100%;
            left: 0;
            margin-top: 8px;
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
            min-width: 280px;
            max-width: 400px;
            max-height: 400px;
            overflow-y: auto;
            z-index: 1000;
            opacity: 0;
            visibility: hidden;
            transform: translateY(-10px);
            transition: all 0.2s ease;
            padding: 12px 0;
        }

        .category-status-wrapper:hover .services-dropdown {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .services-dropdown-header {
            padding: 8px 16px;
            border-bottom: 1px solid #e5e7eb;
            font-weight: 600;
            font-size: 13px;
            color: #374151;
            background: #f9fafb;
        }

        .services-dropdown-list {
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .services-dropdown-item {
            padding: 0;
            border-bottom: 1px solid #f3f4f6;
        }

        .services-dropdown-item:last-child {
            border-bottom: none;
        }

        .services-dropdown-item-link {
            display: block;
            padding: 10px 16px;
            text-decoration: none;
            color: inherit;
            transition: all 0.2s ease;
        }

        .services-dropdown-item-link:hover {
            background: #f3f4f6;
            cursor: pointer;
        }

        .services-dropdown-item-link:hover .services-dropdown-item-name {
            color: #f59e0b;
        }

        .services-dropdown-item-name {
            font-weight: 600;
            color: #1f2937;
            font-size: 14px;
            margin-bottom: 4px;
            transition: color 0.2s ease;
        }

        .services-dropdown-item-issue {
            color: #6b7280;
            font-size: 12px;
            line-height: 1.4;
        }

        .services-dropdown-empty {
            padding: 16px;
            text-align: center;
            color: #9ca3af;
            font-size: 13px;
        }

        .services-dropdown::-webkit-scrollbar {
            width: 6px;
        }

        .services-dropdown::-webkit-scrollbar-track {
            background: #f3f4f6;
            border-radius: 3px;
        }

        .services-dropdown::-webkit-scrollbar-thumb {
            background: #d1d5db;
            border-radius: 3px;
        }

        .services-dropdown::-webkit-scrollbar-thumb:hover {
            background: #9ca3af;
        }
        
        .category-body {
            padding: 16px 20px;
        }
        
        .category-details {
            margin: 0;
            padding: 0;
            list-style: none;
        }
        
        .category-details li {
            position: relative;
            padding-left: 24px;
            margin-bottom: 8px;
            color: #4b5563;
            font-size: 14px;
            line-height: 1.5;
        }
        
        .category-details li:before {
            content: '•';
            position: absolute;
            left: 0;
            color: #f59e0b;
            font-weight: bold;
        }
        
        .category-footer {
            padding: 14px 20px;
            background: #fff7ed;
            border-top: 1px solid #fde68a;
            display: flex;
            justify-content: flex-end;
        }
        
        .btn-view {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: #f59e0b;
            color: white;
            border: none;
            border-radius: 8px;
            padding: 8px 16px;
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s ease;
        }
        
        .btn-view:hover {
            background: #ea580c;
            color: white;
            transform: translateY(-1px);
        }
        
        .empty-state {
            grid-column: 1 / -1;
            text-align: center;
            padding: 40px 20px;
            color: #6b7280;
            background: #fff;
            border: 1px dashed #f3f4f6;
            border-radius: 12px;
        }
        
        .empty-state-icon {
            font-size: 48px;
            margin-bottom: 16px;
            color: #d1d5db;
        }
        
        .empty-state p {
            margin-top: 8px;
            color: #9ca3af;
        }
        
        @media (max-width: 768px) {
            .category-grid {
                grid-template-columns: 1fr;
            }
            
            .page-header {
                flex-direction: column;
                gap: 16px;
                text-align: center;
            }
        }
    </style>
{% endblock %}

{% block content %}
<div class="page-container">
    <div class="page-header">
        <h1>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
            </svg>
            Categories
        </h1>
    </div>
    
    <div class="category-grid">
        {% for category in categories %}
            {% set cnt = countsByCategory[category.id]|default(0) %}
            {% if cnt == 0 %}
                {% set fallback = brandCounts[category.name|lower]|default(0) %}
                {% set cnt = fallback %}
            {% endif %}
            {% set topIssue = topIssueByCategory[category.id]|default(null) %}
            
            <div class="category-card">
                <div class="category-header">
                    <div class="category-header-left">
                        <div class="category-avatar">
                            {{ category.name|first|upper }}
                        </div>
                        <div class="category-info">
                            <h3 class="category-name" title="{{ category.name }}">{{ category.name }}</h3>
                            <div class="category-status-wrapper">
                                <span class="category-status {{ cnt > 0 ? 'active' : '' }}">
                                    {% if cnt > 0 %}
                                        Active ({{ cnt }})
                                    {% else %}
                                        Inactive
                                    {% endif %}
                                </span>
                                {% if cnt > 0 %}
                                    {% set categoryProducts = productsByCategory[category.id]|default([]) %}
                                    <div class="services-dropdown">
                                        <div class="services-dropdown-header">
                                            Active Services ({{ categoryProducts|length }})
                                        </div>
                                        {% if categoryProducts|length > 0 %}
                                            <ul class="services-dropdown-list">
                                                {% for product in categoryProducts %}
                                                    <li class="services-dropdown-item">
                                                        <a href="{{ path('app_product_show', {'id': product.id}) }}" class="services-dropdown-item-link">
                                                            <div class="services-dropdown-item-name">{{ product.name }}</div>
                                                            {% if product.issue %}
                                                                <div class="services-dropdown-item-issue">{{ product.issue|slice(0, 60) }}{% if product.issue|length > 60 %}...{% endif %}</div>
                                                            {% endif %}
                                                        </a>
                                                    </li>
                                                {% endfor %}
                                            </ul>
                                        {% else %}
                                            <div class="services-dropdown-empty">No services found</div>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
                <div class="category-body">
                    <ul class="category-details">
                        {% if topIssue %}
                            <li>Top Issue: {{ topIssue.issue }}</li>
                            <li>Issue Count: {{ topIssue.count }}</li>
                        {% else %}
                            <li>No issues reported</li>
                        {% endif %}
                        <li>Total Services: {{ cnt }}</li>
                    </ul>
                </div>
            </div>
        {% else %}
            <div class="empty-state">
                <div class="empty-state-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                    </svg>
                </div>
                <h3>No Categories Found</h3>
                <p>Get started by adding your first category</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        // Add any category-specific JavaScript here
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });
        });
    </script>
{% endblock %}

