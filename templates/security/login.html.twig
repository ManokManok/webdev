{% extends 'base.html.twig' %}

{% block flashes %}
	{# Flashes shown as toasts in body; do not render default container alerts #}
{% endblock %}

{% block title %}Admin Registration & Login
{% endblock %}

{% block stylesheets %}
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
	<link rel="stylesheet" href="{{ asset('css/login.css') }}">

{% endblock %}

{% block after_body_open %}
	<div id="flash-toasts" class="flash-toasts" aria-live="{{ error ? 'assertive' : 'polite' }}" aria-atomic="true">
		{% for type, messages in app.flashes %}
			{% for message in messages %}
				<div class="flash-toast flash-toast--{{ type == 'error' ? 'danger' : type }}" role="status" data-flash-toast>
					<button type="button" class="flash-toast__close" aria-label="Dismiss">&times;</button>
					<span class="flash-toast__text">{{ message }}</span>
				</div>
			{% endfor %}
		{% endfor %}
		{% if error %}
			<div class="flash-toast flash-toast--danger" role="alert" data-flash-toast>
				<button type="button" class="flash-toast__close" aria-label="Dismiss">&times;</button>
				<span class="flash-toast__text">{{ error.messageKey|trans(error.messageData, 'security') }}</span>
			</div>
		{% endif %}
	</div>
{% endblock %}

{% block body %}
	<div class="login-container">
		<div class="login-card">
			<div class="login-header">
				<div class="login-logo-wrap">
					<img src="{{ asset('images/logo-circular.png') }}" alt="ONINS" class="login-logo-circular">
				</div>
				<p>Sign in to your account or create a customer account</p>
			</div>

			<div class="tab-buttons">
				<button class="tab-button active" onclick="switchTab('login')">Sign In</button>
				<button class="tab-button" onclick="switchTab('register')">Sign Up</button>
			</div>

			{# Login Tab #}
			<div
				id="login-tab" class="tab-content active">
				{# Login errors shown as toast in #flash-toasts #}

				{# Login Form - POST to login_check as configured in security.yaml #}
				<form method="post" action="{{ path('app_login_check') }}" id="login-form">
					<div class="form-group">
						<label for="username" class="form-label">Email</label>
						<input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control" autocomplete="email" required autofocus placeholder="Enter your email">
					</div>
					<div class="form-group">
						<label for="password" class="form-label">Password</label>
						<input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" required placeholder="Enter your password">
					</div>

					{# CSRF Token - Required for security #}
					<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

					<button class="btn btn-login" type="submit" name="login_submit">
						<span>Sign In</span>
					</button>
				</form>

				<hr class="auth-divider" aria-hidden="true">

				<div class="auth-wrapper">
					<a href="{{ path('connect_google_start') }}" id="google-login-link" class="btn-google">
						<span class="icon-left">
							<svg viewBox="0 -2 30 30" xmlns="http://www.w3.org/2000/svg">
								<g transform="matrix(1, 0, 0, 1, 27.009766, -39.238281)">
									<path fill="#4285F4" d="M -3.264 51.6 C -3.264 50.952 -3.334 50.247 -3.454 49.572 L -14.754 49.572 L -14.754 53.382 L -8.284 53.382 C -8.574 54.572 -9.424 55.482 -10.684 56.072 L -10.684 58.782 L -6.884 58.782 C -4.294 56.482 -3.264 53.222 -3.264 51.6 Z"/>
									<path fill="#34A853" d="M -14.754 61.001 C -11.514 61.001 -8.804 59.991 -6.884 58.782 L -10.684 56.072 C -11.764 56.752 -13.134 57.121 -14.754 57.121 C -17.884 57.121 -20.534 55.001 -21.484 52.181 L -25.464 52.181 L -25.464 54.991 C -23.534 59.121 -19.444 61.001 -14.754 61.001 Z"/>
									<path fill="#FBBC04" d="M -21.484 52.181 C -21.774 51.381 -21.934 50.531 -21.934 49.621 C -21.934 48.711 -21.784 47.861 -21.484 47.061 L -21.484 44.251 L -25.464 44.251 C -26.284 46.001 -26.754 47.911 -26.754 49.621 C -26.754 51.331 -26.284 53.241 -25.464 54.991 L -21.484 52.181 Z"/>
									<path fill="#EA4335" d="M -14.754 42.121 C -13.004 42.121 -11.404 42.721 -10.154 43.831 L -6.734 40.411 C -8.804 38.691 -11.514 37.621 -14.754 37.621 C -19.444 37.621 -23.534 39.501 -25.464 43.631 L -21.484 46.441 C -20.534 43.621 -17.884 42.121 -14.754 42.121 Z"/>
								</g>
							</svg>
						</span>
						<span>Continue with Google</span>
					</a>
				</div>

				<div class="demo-accounts" aria-label="Demo login credentials">
					<p class="demo-accounts-title">Demo accounts — click to fill</p>
					<div class="demo-accounts-row">
						<button type="button" class="demo-account-btn demo-account-btn--customer" data-demo-email="customer@onins.com" data-demo-password="customer123">Customer</button>
						<button type="button" class="demo-account-btn" data-demo-email="admin@onins" data-demo-password="admin123">Admin</button>
						<button type="button" class="demo-account-btn" data-demo-email="stockadmin@cabajon.com" data-demo-password="admin123">Stock Admin</button>
						<button type="button" class="demo-account-btn" data-demo-email="stockmanager@cabajon.com" data-demo-password="staff123">Staff</button>
					</div>
				</div>
			</div>

			{# Registration Tab - Customer Registration Only #}
			<div
				id="register-tab" class="tab-content">
				{# Customer Registration Form #}
				{% if registrationForm is defined %}
					<form action="{{ path('app_register') }}" method="post" id="registration-form" novalidate>
						<input type="hidden" name="form_type" value="registration">
						{{ form_widget(registrationForm._token) }}
						<div class="form-group">
							{{ form_label(registrationForm.username, null, {'label_attr': {'class': 'form-label'}}) }}
							{{ form_widget(registrationForm.username, {'attr': {'class': 'form-control', 'placeholder': 'Enter your name'}}) }}
							{{ form_errors(registrationForm.username) }}
						</div>

						<div class="form-group">
							{{ form_label(registrationForm.email, null, {'label_attr': {'class': 'form-label'}}) }}
							{{ form_widget(registrationForm.email, {'attr': {'class': 'form-control', 'placeholder': 'Enter your email'}}) }}
							{{ form_errors(registrationForm.email) }}
						</div>

						<div class="form-group">
							{{ form_label(registrationForm.plainPassword.first, null, {'label_attr': {'class': 'form-label'}}) }}
							{{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'form-control', 'placeholder': 'Enter your password'}}) }}
							{{ form_errors(registrationForm.plainPassword.first) }}
						</div>

						<div class="form-group">
							{{ form_label(registrationForm.plainPassword.second, null, {'label_attr': {'class': 'form-label'}}) }}
							{{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'form-control', 'placeholder': 'Confirm your password'}}) }}
							{{ form_errors(registrationForm.plainPassword.second) }}
						</div>

						<button type="submit" class="btn btn-register">
							<span>Sign Up</span>
						</button>
					</form>
				{% endif %}
			</div>

			{# <div class="login-footer">
			            <p class="mb-0">© 2024 ONINS. All rights reserved.</p>
			        </div> #}
		</div>
	</div>

	<script>
		function switchTab(tab) { // Hide all tabs
document.querySelectorAll('.tab-content').forEach(content => {
content.classList.remove('active');
});

// Remove active class from all buttons
document.querySelectorAll('.tab-button').forEach(button => {
button.classList.remove('active');
});

// Show selected tab
if (tab === 'login') {
document.getElementById('login-tab').classList.add('active');
document.querySelectorAll('.tab-button')[0].classList.add('active');
} else {
document.getElementById('register-tab').classList.add('active');
document.querySelectorAll('.tab-button')[1].classList.add('active');
}
}

// Prevent form submissions without required fields
document.addEventListener('DOMContentLoaded', function () {
const loginForm = document.getElementById('login-form');
const registrationForm = document.getElementById('registration-form');

if (loginForm) { // Ensure login form always submits to login_check via POST
const loginCheckAction = '{{ path('app_login_check') }}';

loginForm.addEventListener('submit', function (e) {
const username = document.getElementById('username').value.trim();
const password = document.getElementById('password').value.trim();

if (! username || ! password) {
e.preventDefault();
alert('Please enter both email and password.');
return false;
}

// Ensure form method is POST and action is correct
this.method = 'post';
this.action = loginCheckAction;
});
}

if (registrationForm) { // Force the registration form to always submit to register
const registerAction = '{{ path('app_register') }}';
registrationForm.action = registerAction;

registrationForm.addEventListener('submit', function (e) { // Double-check the action is correct before submitting
if (this.action !== registerAction && this.action.indexOf('register') === -1) {
e.preventDefault();
this.action = registerAction;
this.submit();
return false;
}
});
}

document.querySelectorAll('[data-demo-email]').forEach(function (btn) {
btn.addEventListener('click', function () {
const userEl = document.getElementById('username');
const passEl = document.getElementById('password');
if (userEl && passEl) {
userEl.value = btn.getAttribute('data-demo-email') || '';
passEl.value = btn.getAttribute('data-demo-password') || '';
switchTab('login');
userEl.focus();
}
});
});

document.querySelectorAll('[data-flash-toast]').forEach(function (toast) {
const remove = function () {
toast.classList.add('flash-toast--out');
setTimeout(function () {
toast.remove();
}, 280);
};
const t = setTimeout(remove, 7000);
toast.querySelector('.flash-toast__close')?.addEventListener('click', function () {
clearTimeout(t);
remove();
});
});
});
	</script>
{% endblock %}
