{% extends 'base.html.twig' %}

{% block flashes %}
{% endblock %}

{% block title %}Register - Admin Panel{% endblock %}

{% block stylesheets %}
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
	<link rel="stylesheet" href="{{ asset('css/register.css') }}">
{% endblock %}

{% block body %}
<div id="flash-toasts" class="flash-toasts" aria-live="polite" aria-atomic="true">
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash-toast flash-toast--{{ type == 'error' ? 'danger' : type }}" role="status" data-flash-toast>
                <button type="button" class="flash-toast__close" aria-label="Dismiss">&times;</button>
                <span class="flash-toast__text">{{ message }}</span>
            </div>
        {% endfor %}
    {% endfor %}
</div>
<div class="register-container">
    <div class="register-card">
        <div class="register-header">
            <h1>Create Account</h1>
            <p>Sign up to get started</p>
        </div>
        <div class="register-body">
            {# Registration Form #}
            {{ form_start(registrationForm) }}
                <div class="form-group">
                    {{ form_label(registrationForm.fullName, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(registrationForm.fullName, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(registrationForm.fullName) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.username, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(registrationForm.username, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(registrationForm.username) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.plainPassword.first, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(registrationForm.plainPassword.first) }}
                </div>

                <div class="form-group">
                    {{ form_label(registrationForm.plainPassword.second, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(registrationForm.plainPassword.second) }}
                </div>

                <button type="submit" class="btn btn-register">
                    Create Account
                </button>
            {{ form_end(registrationForm) }}

            <a href="{{ path('app_login') }}" class="btn-link">
                Already have an account? Sign in
            </a>
        </div>
        {# <div class="register-footer">
            <p class="mb-0">© 2024 ONINS Admin Panel. All rights reserved.</p>
        </div> #}
    </div>
</div>
<script>
document.querySelectorAll('[data-flash-toast]').forEach(function (toast) {
    var remove = function () {
        toast.classList.add('flash-toast--out');
        setTimeout(function () { toast.remove(); }, 280);
    };
    var t = setTimeout(remove, 7000);
    var btn = toast.querySelector('.flash-toast__close');
    if (btn) {
        btn.addEventListener('click', function () {
            clearTimeout(t);
            remove();
        });
    }
});
</script>
{% endblock %}

