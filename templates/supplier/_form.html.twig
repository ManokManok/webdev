{{ form_start(form, {'attr': {'class': 'supplier-form', 'novalidate': 'novalidate'}}) }}
    <div class="form-sections">
        {# Basic Information Section #}
        <div class="form-section">
            <h3 class="section-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                    <circle cx="12" cy="7" r="4"></circle>
                </svg>
                Basic Information
            </h3>
            
            <div class="form-row">
                <div class="form-group">
                    <div class="input-group">
                        <span class="input-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                <circle cx="12" cy="7" r="4"></circle>
                            </svg>
                        </span>
                        {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': ' '}}) }}
                        {{ form_label(form.name, 'Supplier Name *', {'label_attr': {'class': 'form-label'}}) }}
                    </div>
                    {{ form_errors(form.name) }}
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <div class="input-group">
                        <span class="input-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                                <polyline points="22,6 12,13 2,6"></polyline>
                            </svg>
                        </span>
                        {{ form_widget(form.contact, {'attr': {'class': 'form-control', 'placeholder': ' '}}) }}
                        {{ form_label(form.contact, 'Contact Email', {'label_attr': {'class': 'form-label'}}) }}
                    </div>
                    {{ form_errors(form.contact) }}
                </div>
            </div>
        </div>
    </div>

    <div class="form-actions">
        <a href="{{ path('app_supplier_index') }}" class="btn btn-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Cancel
        </a>
        <button type="submit" class="btn btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
                <polyline points="17 21 17 13 7 13 7 21"></polyline>
                <polyline points="7 3 7 8 15 8"></polyline>
            </svg>
            {{ button_label|default('Save Supplier') }}
        </button>
    </div>
{{ form_end(form) }}

<style>
    .supplier-form {
        max-width: 600px;
    }

    .form-sections {
        margin-bottom: 24px;
    }

    .form-section {
        background: #fff;
        border: 2px solid #fde68a;
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 20px;
        box-shadow: 0 4px 12px rgba(245, 158, 11, 0.08);
    }

    .section-title {
        font-size: 16px;
        font-weight: 700;
        color: #92400e;
        margin: 0 0 20px 0;
        padding-bottom: 12px;
        border-bottom: 2px solid #fde68a;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .section-title svg {
        color: #f59e0b;
    }

    .form-row {
        margin-bottom: 16px;
    }

    .form-group {
        position: relative;
    }

    .input-group {
        position: relative;
    }

    .input-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #9ca3af;
        z-index: 10;
        pointer-events: none;
    }

    .form-control {
        width: 100%;
        padding: 14px 14px 14px 44px;
        font-size: 14px;
        border: 2px solid #e5e7eb;
        border-radius: 10px;
        background: #fff;
        transition: all 0.2s ease;
        color: #1f2937;
    }

    .form-control:focus {
        outline: none;
        border-color: #f59e0b;
        box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.1);
    }

    .form-control::placeholder {
        color: transparent;
    }

    .form-label {
        position: absolute;
        left: 44px;
        top: 14px;
        font-size: 14px;
        color: #6b7280;
        pointer-events: none;
        transition: all 0.2s ease;
        background: transparent;
    }

    .form-control:focus ~ .form-label,
    .form-control:not(:placeholder-shown) ~ .form-label {
        top: -8px;
        left: 12px;
        font-size: 12px;
        color: #f59e0b;
        background: #fff;
        padding: 0 4px;
        font-weight: 600;
    }

    .form-actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
        padding-top: 20px;
        border-top: 2px solid #fde68a;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 24px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s ease;
        border: none;
        cursor: pointer;
    }

    .btn-primary {
        background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%);
        color: white;
        box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(245, 158, 11, 0.4);
    }

    .btn-secondary {
        background: #fff;
        color: #92400e;
        border: 2px solid #fbbf24;
    }

    .btn-secondary:hover {
        background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
    }

    .form-error-message {
        color: #dc2626;
        font-size: 13px;
        margin-top: 6px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .form-error-message::before {
        content: '⚠️';
    }

    ul.form-error-message {
        list-style: none;
        padding: 0;
        margin: 6px 0 0 0;
    }
</style>

