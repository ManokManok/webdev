{% extends 'supplier/base.html.twig' %}

{% block supplier_title %}Edit Supplier{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .page-container {
            max-width: 100%;
            margin: 0;
            padding: 24px 32px;
        }

        .page-header {
            background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%);
            border-radius: 20px;
            padding: 28px 32px;
            margin: 0 0 28px 0;
            display: flex;
            align-items: center;
            gap: 16px;
            box-shadow: 0 10px 32px rgba(245, 158, 11, 0.3);
            color: #fff;
        }

        .page-header h1 {
            margin: 0;
            font-weight: 800;
            font-size: 24px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .page-header svg {
            width: 28px;
            height: 28px;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: rgba(255, 255, 255, 0.9);
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
            margin-left: auto;
            padding: 8px 16px;
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.15);
            transition: all 0.2s ease;
        }

        .back-link:hover {
            background: rgba(255, 255, 255, 0.25);
            color: white;
            text-decoration: none;
        }

        .content-wrapper {
            max-width: 700px;
        }
    </style>
{% endblock %}

{% block content %}
<div class="page-container">
    <div class="page-header">
        <h1>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
            Edit Supplier
        </h1>
        <a href="{{ path('app_supplier_index') }}" class="back-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to Suppliers
        </a>
    </div>

    <div class="content-wrapper">
        {{ include('supplier/_form.html.twig', {form: form, button_label: 'Update Supplier'}) }}
    </div>
</div>
{% endblock %}
