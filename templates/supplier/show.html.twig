{% extends 'supplier/base.html.twig' %}

{% block supplier_title %}Supplier {{ supplier.name }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .page-container {
            max-width: 100%;
            margin: 0;
            padding: 24px 32px;
        }

        /* Header */
        .hero {
            background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%);
            border-radius: 20px;
            padding: 28px 32px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 10px 32px rgba(245, 158, 11, 0.3);
            color: #fff;
            margin-bottom: 24px;
        }

        .hero-title {
            margin: 0;
            font-weight: 800;
            font-size: 24px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .hero-actions {
            display: flex;
            gap: 10px;
        }

        .btn-hero {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 18px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s ease;
            border: none;
            cursor: pointer;
        }

        .btn-hero-back {
            background: rgba(255, 255, 255, 0.2);
            color: white;
        }

        .btn-hero-back:hover {
            background: rgba(255, 255, 255, 0.3);
            color: white;
        }

        .btn-hero-edit {
            background: white;
            color: #ea580c;
        }

        .btn-hero-edit:hover {
            background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
        }

        .btn-hero-delete {
            background: #fef2f2;
            color: #dc2626;
        }

        .btn-hero-delete:hover {
            background: #fee2e2;
        }

        /* Breadcrumb */
        .crumbs {
            font-size: 14px;
            color: #92400e;
            margin-bottom: 16px;
        }

        .crumbs a {
            color: #92400e;
            text-decoration: none;
        }

        .crumbs a:hover {
            text-decoration: underline;
        }

        /* Info Chips */
        .chips {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 24px;
        }

        .chip {
            background: #fff;
            border: 2px solid #fde68a;
            color: #92400e;
            border-radius: 12px;
            padding: 12px 20px;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 4px 12px rgba(245, 158, 11, 0.08);
        }

        .chip b {
            color: #ea580c;
        }

        .chip svg {
            width: 18px;
            height: 18px;
            color: #f59e0b;
        }

        /* Section Card */
        .sup-sec {
            background: #fff;
            border: 2px solid #fde68a;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 4px 16px rgba(245, 158, 11, 0.1);
        }

        .sup-head {
            padding: 16px 24px;
            background: linear-gradient(90deg, #fff7ed, #ffedd5);
            border-bottom: 2px solid #fde68a;
            color: #92400e;
            font-weight: 700;
            font-size: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sup-content {
            padding: 24px;
            color: #78350f;
        }

        .sup-content ul {
            margin: 0;
            padding-left: 20px;
        }

        .sup-content li {
            margin-bottom: 8px;
        }

        /* Stock Card */
        .stock-card {
            background: #fff;
            border: 2px solid #fde68a;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 4px 16px rgba(245, 158, 11, 0.1);
            margin-top: 20px;
        }

        .stock-head {
            padding: 14px 24px;
            background: linear-gradient(90deg, #fff7ed, #ffedd5);
            border-bottom: 2px solid #fde68a;
            color: #92400e;
            font-weight: 700;
            font-size: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .pill {
            border-radius: 20px;
            padding: 4px 14px;
            font-size: 13px;
            font-weight: 600;
        }

        .pill-high {
            background: #f59e0b;
            color: #fff;
        }

        .pill-low {
            background: #fb923c;
            color: #fff;
        }

        .table-responsive {
            padding: 0 16px 16px;
        }

        .table {
            width: 100%;
            border-collapse: collapse;
        }

        .table th {
            text-align: left;
            padding: 12px;
            color: #92400e;
            font-weight: 600;
            border-bottom: 2px solid #fde68a;
        }

        .table th.text-end {
            text-align: right;
        }

        .table td {
            padding: 12px;
            color: #78350f;
            border-bottom: 1px solid #fff7ed;
        }

        .table td.text-end {
            text-align: right;
        }

        .badge-high {
            background: #f59e0b;
            color: #fff;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .badge-low {
            background: #fb923c;
            color: #fff;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }
    </style>
{% endblock %}

{% block content %}
<div class="page-container">
    <div class="crumbs">
        <a href="{{ path('app_supplier_index') }}">Suppliers</a> / <span>{{ supplier.name }}</span>
    </div>

    <div class="hero">
        <h1 class="hero-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
            {{ supplier.name }}
        </h1>
        <div class="hero-actions">
            <a href="{{ path('app_supplier_index') }}" class="btn-hero btn-hero-back">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Back
            </a>
            <a href="{{ path('app_supplier_edit', {id: supplier.id}) }}" class="btn-hero btn-hero-edit">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                </svg>
                Edit
            </a>
            <form method="post" action="{{ path('app_supplier_delete', {id: supplier.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this supplier?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ supplier.id) }}">
                <button type="submit" class="btn-hero btn-hero-delete">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="3 6 5 6 21 6"></polyline>
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                    </svg>
                    Delete
                </button>
            </form>
        </div>
    </div>

    <div class="chips">
        <span class="chip">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="4" y1="9" x2="20" y2="9"></line>
                <line x1="4" y1="15" x2="20" y2="15"></line>
                <line x1="10" y1="3" x2="8" y2="21"></line>
                <line x1="16" y1="3" x2="14" y2="21"></line>
            </svg>
            <b>ID</b> {{ supplier.id }}
        </span>
        <span class="chip">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            <b>Contact</b> {{ supplier.contact ?: 'No contact provided' }}
        </span>
        <span class="chip">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
                <path d="M2 17l10 5 10-5"></path>
                <path d="M2 12l10 5 10-5"></path>
            </svg>
            <b>Products</b> {{ supplier.products|length }}
        </span>
    </div>

    <div class="sup-sec">
        <div class="sup-head">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
                <line x1="16" y1="13" x2="8" y2="13"></line>
                <line x1="16" y1="17" x2="8" y2="17"></line>
            </svg>
            Supplied Products or Services
        </div>
        <div class="sup-content">
            {% if supplier.name matches '/Mobile Parts Depot/i' %}
                <ul>
                    <li><strong>List of available parts:</strong></li>
                    <ul>
                        <li>Screens & LCDs</li>
                        <li>Batteries</li>
                        <li>Charging ports & cables</li>
                        <li>Motherboards</li>
                        <li>IC chips & small components</li>
                        <li>Phone casings, buttons, adhesives, etc.</li>
                    </ul>
                </ul>
            {% elseif supplier.name matches '/GigaTech Supplies/i' %}
                <ul>
                    <li>Software tools or licenses (e.g., flashing tools, diagnostic apps)</li>
                    <li>Repair consumables (e.g., cleaning fluid, solder, glue, tools)</li>
                </ul>
            {% elseif supplier.name matches '/City Electronics Wholesale/i' %}
                <ul>
                    <li>Warranty information for supplied parts</li>
                    <li>Product catalog with pricing and availability</li>
                </ul>
            {% else %}
                <div class="text-muted">No specific list provided for this supplier.</div>
            {% endif %}

            {% set stock_data = {
                'City Electronics Wholesale': [
                    { 'name': 'Screen protectors', 'qty': 200 },
                    { 'name': 'Phone cases', 'qty': 65 },
                    { 'name': 'Adhesive strips', 'qty': 14 },
                    { 'name': 'Cleaning swabs', 'qty': 10 },
                    { 'name': 'Charging cables', 'qty': 45 }
                ],
                'GigaTech Supplies': [
                    { 'name': 'Flashing tool licenses', 'qty': 12 },
                    { 'name': 'Diagnostic app seats', 'qty': 26 },
                    { 'name': 'Cleaning fluid (bottles)', 'qty': 30 },
                    { 'name': 'Solder wire (spools)', 'qty': 8 },
                    { 'name': 'Precision tool kits', 'qty': 14 }
                ],
                'Mobile Parts Depot': [
                    { 'name': 'Screens & LCDs', 'qty': 42 },
                    { 'name': 'Batteries', 'qty': 15 },
                    { 'name': 'Charging ports & cables', 'qty': 9 },
                    { 'name': 'Motherboards', 'qty': 6 },
                    { 'name': 'IC chips & small components', 'qty': 120 },
                    { 'name': 'Phone casings, buttons, adhesives', 'qty': 18 }
                ]
            } %}

            {% for supplier_name, items in stock_data %}
                {% if supplier.name matches '/' ~ supplier_name ~ '/i' %}
                    {% set highCount = items|filter(it => it.qty >= 20)|length %}
                    {% set lowCount = items|length - highCount %}
                    <div class="stock-card">
                        <div class="stock-head">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
                                <path d="M2 17l10 5 10-5"></path>
                            </svg>
                            Stock Overview
                        </div>
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Item</th>
                                        <th class="text-end">Quantity</th>
                                        <th class="text-end">Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for item in items %}
                                        <tr>
                                            <td>{{ item.name }}</td>
                                            <td class="text-end">{{ item.qty }}</td>
                                            <td class="text-end">
                                                {% if item.qty >= 20 %}
                                                    <span class="badge-high">High</span>
                                                {% else %}
                                                    <span class="badge-low">Low</span>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                        <div style="padding: 12px 24px; background: #fff7ed; border-top: 2px solid #fde68a; display: flex; gap: 10px; justify-content: flex-end;">
                            <span class="pill pill-high">High Stock: {{ highCount }}</span>
                            <span class="pill pill-low">Low Stock: {{ lowCount }}</span>
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}
