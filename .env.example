# Copy to .env for local development (never commit .env).

APP_ENV=dev
APP_SECRET=change_me_locally

# Local Docker MySQL (docker compose up -d)
MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=nino
MYSQL_USER=ninocabajon
MYSQL_PASSWORD=change_me
MYSQL_PORT=3309
DATABASE_URL="mysql://ninocabajon:change_me@127.0.0.1:3309/nino?serverVersion=8.0&charset=utf8mb4"

MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
MAILER_DSN=null://null

# Mobile / LAN CORS (adjust for your network)
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1|192\.168\.\d+\.\d+|10\.\d+\.\d+\.\d+)(:[0-9]+)?$'

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_BASE=http://127.0.0.1:8000

JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me
JWT_TOKEN_TTL=604800

###> symfony/mercure-bundle ###
MERCURE_URL=http://127.0.0.1:3000/.well-known/mercure
MERCURE_PUBLIC_URL=http://127.0.0.1:3000/.well-known/mercure
MERCURE_JWT_SECRET=change_me_mercure_secret
###< symfony/mercure-bundle ###

###> firebase / FCM (system push when orders are approved/rejected) ###
# Download service account JSON from Firebase Console → Project settings → Service accounts
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=%kernel.project_dir%/config/firebase-credentials.json
###< firebase / FCM ###
