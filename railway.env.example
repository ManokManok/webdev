# Copy these into Railway → webdev service → Variables (production).
# Use "Add Reference" on the MySQL service for database credentials (required).

# --- Required: link MySQL (Add Reference → MySQL) ---
DATABASE_URL=${{MySQL.DATABASE_URL}}

# Or reference individual vars if you prefer:
# MYSQLHOST=${{MySQL.MYSQLHOST}}
# MYSQLPORT=${{MySQL.MYSQLPORT}}
# MYSQLUSER=${{MySQL.MYSQLUSER}}
# MYSQLPASSWORD=${{MySQL.MYSQLPASSWORD}}
# MYSQLDATABASE=${{MySQL.MYSQLDATABASE}}

# --- Required: set a strong random secret (do not use the build default) ---
APP_SECRET=replace_with_long_random_string

# --- Public URL (OAuth + absolute links). Railway usually sets RAILWAY_PUBLIC_DOMAIN automatically. ---
APP_PUBLIC_URL=https://webdev-production-c694.up.railway.app
GOOGLE_OAUTH_CALLBACK_BASE=https://webdev-production-c694.up.railway.app

# --- Optional: Google Sign-In (add redirect URI in Google Cloud Console) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Optional: force reload demo catalog on deploy ---
# RUN_FIXTURES=1
